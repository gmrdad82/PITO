# Copy to .env for local use. CI uses its own env vars (see .github/workflows/ci.yml).
# For Docker boot via bin/boot, place required vars here or export them in your shell.

# ── bin/boot (production) ─────────────────────────────────────────────
# Required for production mode. Get it from config/master.key or 1Password.
# RAILS_MASTER_KEY=

# ── bin/boot --dev (development) ──────────────────────────────────────
# No master key needed. The dev image mounts the repo root including config/.

# ── Ports ─────────────────────────────────────────────────────────────
# Host-side port for the web service (container always binds 3027 in dev, 80 in prod).
WEB_PORT=3027
POSTGRES_PORT=54327

# ── Postgres (non-Docker / local bin/dev) ─────────────────────────────
POSTGRES_HOST=127.0.0.1

# ── ActiveStorage path override (non-Docker) ──────────────────────────
# In Docker the named volume is mounted at /var/lib/pito-assets automatically.
# For bin/dev (local Ruby), override to a local path:
# PITO_ASSETS_PATH=storage
