<% content_for(:title, "authorize application") %>
<% content_for(:hide_chrome, true) %>

<%# Phase 7.5 — Doorkeeper consent page restyled to match Pito's design
    system. `:hide_chrome` strips the header/footer to logo + theme
    toggle (mirrors `sessions/new.html.erb`). The page uses Pito's
    monospace stack (inherited from the layout), design tokens, and the
    bracketed-link convention. The `<button>` keeps `[authorize]` as
    inline bracketed text so the form submits correctly; cancel is a
    BracketedMutedLinkComponent — the app-wide muted bracketed-link
    primitive (sibling to BracketedLinkComponent), here with its default
    `label: "cancel"` so it reads as the lesser action / exit. Muted at
    rest, darkens to text on hover; distinct from the link-colored
    primary action and the red destructive action. Single-user install
    — the intro copy and per-scope explanations were trimmed; the user
    knows what they're authorizing. %>
<div style="max-width: 480px; margin: 24px 0;">
  <h1>authorize <%= @pre_auth.client.name %></h1>

  <%# Phase 7.5 — application metadata uses the pane look
      (`.pane.pane--standalone`) so this consent-screen detail surface
      reads visually consistent with `settings/oauth_applications/create.html.erb`
      and `show.html.erb`. Label cells carry `padding-right: 12px;`
      so labels don't kiss values — the base `.detail-table td`
      rule has `padding: 1px 0;` (no horizontal padding). %>
  <div class="pane pane--standalone">
    <table class="detail-table">
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">redirect URI</td>
        <td><code><%= @pre_auth.redirect_uri %></code></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">client_id</td>
        <td><code><%= @pre_auth.client.uid %></code></td>
      </tr>
    </table>
  </div>

  <%= form_tag oauth_authorization_path, method: :post, data: { turbo: false } do %>
    <%= hidden_field_tag :client_id, @pre_auth.client.uid, id: nil %>
    <%= hidden_field_tag :redirect_uri, @pre_auth.redirect_uri, id: nil %>
    <%= hidden_field_tag :state, @pre_auth.state, id: nil %>
    <%= hidden_field_tag :response_type, @pre_auth.response_type, id: nil %>
    <%= hidden_field_tag :response_mode, @pre_auth.response_mode, id: nil %>
    <%= hidden_field_tag :scope, @pre_auth.scope, id: nil %>
    <%= hidden_field_tag :code_challenge, @pre_auth.code_challenge, id: nil %>
    <%= hidden_field_tag :code_challenge_method, @pre_auth.code_challenge_method, id: nil %>

    <div class="dot-list">
      <button type="submit">[authorize]</button>
      <%= render(BracketedMutedLinkComponent.new(href: root_path)) %>
    </div>
  <% end %>
</div>
