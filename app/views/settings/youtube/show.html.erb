<% content_for(:title, "Google connection") %>
<% breadcrumb(["settings", settings_path], "Google") %>

<div style="margin-bottom: 8px;">
  <h1>Google connection</h1>
</div>

<%# Phase 10 polish — single consolidated top-of-page reconnect banner.
    The pane-internal `[reconnect]` button and the picker-section red
    banner are gone (the top banner is the primary CTA). Two copy
    variants live in the partial (revoked grant vs. missing scopes);
    transient API errors render their own muted note further down.

    `@youtube_error` carrying an auth-state token like "needsreauth"
    is suppressed here — when `needs_reauth?` is true the user already
    sees the top banner. Only genuine transient errors (quota, 5xx)
    surface a secondary muted note in the picker section. %>
<% if @youtube_connection.present? && @youtube_connection.needs_reauth? %>
  <%= render "settings/youtube/needs_reauth_banner" %>
<% end %>

<% if @youtube_connection.nil? %>
  <%# Empty state — no Google account connected. %>
  <div class="pane pane--standalone" style="margin-top: 12px; padding: 16px; max-width: 60ch;">
    <p>no Google account connected.</p>

    <%= form_with url: settings_youtube_connect_path, method: :post,
                  data: { turbo: false } do %>
      <button type="submit">[connect]</button>
    <% end %>

    <p class="text-muted" style="margin-top: 8px;">
      pito requests <code>youtube.readonly</code> and
      <code>yt-analytics.readonly</code>.<br>
      read-only — pito cannot upload, edit, or delete your videos with
      these scopes.
    </p>
  </div>
<% else %>
  <%# Connected state. Connection metadata pane.

      Width — `.pane.pane--wide` (904px) replaces the previous
      `pane--standalone` + `max-width: 60ch` constraint. The pane
      carries the scopes list (one per line, full URL under each
      label) and email addresses that would otherwise wrap or truncate
      in a narrow column.

      `[reconnect]` lives ONLY in the top banner now (when
      `needs_reauth?`). The pane no longer offers a duplicate. %>
  <div class="pane-row">
    <div class="pane pane--wide" style="padding: 16px;">
      <table class="detail-table" style="margin-bottom: 0;">
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">connected as</td>
          <td><strong><%= @youtube_connection.email %></strong></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">last authorized</td>
          <td><%= @youtube_connection.last_authorized_at.strftime("%Y-%m-%d %H:%M %Z") %></td>
        </tr>
        <% if @youtube_connection.last_refreshed_at.present? %>
          <tr>
            <td class="text-muted" style="padding-right: 12px; vertical-align: top;">last refreshed</td>
            <td><%= @youtube_connection.last_refreshed_at.strftime("%Y-%m-%d %H:%M %Z") %></td>
          </tr>
        <% end %>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">scopes</td>
          <td>
            <%# Each scope on its own row. The trailing path segment is
                bolded (the readable name the user thinks of —
                `youtube.readonly`); the full URL sits muted below for
                disambiguation without drowning the surface. %>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <% Array(@youtube_connection.scopes).each do |scope| %>
                <% short = scope.to_s.split("/").last.presence || scope.to_s %>
                <li style="margin-bottom: 4px;">
                  <code><strong><%= short %></strong></code><br>
                  <span class="text-muted" style="font-size: 0.85em;"><%= scope %></span>
                </li>
              <% end %>
            </ul>
          </td>
        </tr>
      </table>
    </div>
  </div>

  <%# Currently-linked channels — every Channel row whose
      youtube_connection_id points at this connection. Surfaces the
      install's already-added set so the user can disconnect any of
      them via the existing /deletions/youtube_connection/:id action
      screen (no JS confirm; hard rule). Empty list collapses the
      section to a one-line muted note. %>
  <% linked_channels = Channel.where(youtube_connection_id: @youtube_connection.id).order(:channel_url) %>
  <h2 style="margin-top: 16px;">linked channels</h2>
  <% if linked_channels.any? %>
    <table>
      <thead>
        <tr>
          <th>channel</th>
          <th>state</th>
        </tr>
      </thead>
      <tbody>
        <% linked_channels.each do |c| %>
          <tr>
            <td style="font-family: monospace;">
              <%= link_to c.channel_url.sub(%r{\Ahttps?://(www\.)?youtube\.com/channel/}, ""),
                          channel_path(c) %>
            </td>
            <td>
              <%= form_with url: deletions_path(type: "youtube_connection", ids: c.id),
                            method: :get, data: { turbo: false },
                            html: { style: "display: inline;" } do %>
                <button type="submit">[disconnect]</button>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no channels linked yet.</p>
  <% end %>

  <%# Channel-select picker — the multi-select form. Each row carries
      a checkbox keyed by YouTube channel ID; ticked rows roll up into
      `youtube_channel_ids[]` on submit. Rows already linked to this
      connection render with a disabled checkbox and an "already
      added" marker so the form can't re-submit them. %>
  <h2 style="margin-top: 16px;">select channels to add</h2>

  <% if @youtube_connection.needs_reauth? %>
    <%# Auth-state failure (insufficient scopes, refresh-token
        revoked, …). The top banner already carries the `[reconnect]`
        CTA — here we collapse the picker to a small muted note
        instead of a third red full-width banner. The linked-channels
        section above renders unaffected — those rows come from the
        local Channels table, not the YouTube API. %>
    <p class="text-muted">
      channel list will return after <strong>[reconnect]</strong> above.
    </p>
  <% else %>
    <% if @youtube_error.present? %>
      <%# Transient API failure (quota exhausted, 5xx). The error
          string is human-readable here (e.g. "quota exceeded"); the
          legacy `needsreauth` / `transient` class-name leak is
          shielded by the `needs_reauth?` guard above. Map the
          remaining internal token "transient" to a clean phrase
          before display. %>
      <% human_error = case @youtube_error.to_s
                       when "transient" then "service temporarily unavailable"
                       else @youtube_error.to_s
                       end %>
      <div class="flash-error" style="margin: 12px 0; padding: 10px 12px; border: 1px solid #cc0000; color: #cc0000;">
        YouTube api unavailable right now: <%= human_error %>.
        can't list channels to add right now.
      </div>
    <% end %>

    <% pito_channels_by_url = Channel.where(channel_url: @youtube_channels.map { |c| "https://www.youtube.com/channel/#{c[:id]}" }).index_by(&:channel_url) %>

    <% if @youtube_channels.any? %>
      <%= form_with url: settings_youtube_channels_path, method: :post,
                    data: { turbo: false } do %>
        <table>
          <thead>
            <tr>
              <th class="col-action"></th>
              <th></th>
              <th>title</th>
              <th class="num">subscribers</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @youtube_channels.each do |channel| %>
              <% url = "https://www.youtube.com/channel/#{channel[:id]}" %>
              <%= render "settings/youtube/channel_row",
                         channel: channel,
                         pito_channel: pito_channels_by_url[url] %>
            <% end %>
          </tbody>
        </table>

        <div style="margin-top: 8px;">
          <button type="submit" class="btn-submit">[<b>add channels</b>]</button>
        </div>
      <% end %>
    <% elsif @youtube_error.blank? %>
      <p class="text-muted">no channels found under this Google account.</p>
    <% end %>
  <% end %>
<% end %>
