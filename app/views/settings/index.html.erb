<h1 class="text-base font-bold mb-2">Settings</h1>

<%= form_with url: settings_path, method: :patch, class: "max-w-lg" do |f| %>
  <fieldset class="mb-4">
    <legend class="font-bold text-sm mb-2">YouTube OAuth</legend>

    <div class="mb-2">
      <label for="settings_youtube_client_id" class="block text-xs font-semibold mb-0.5">Client ID</label>
      <input type="text" name="settings[youtube_client_id]" id="settings_youtube_client_id"
             value="<%= @settings['youtube_client_id'] %>" autocomplete="off">
    </div>

    <div class="mb-2">
      <label for="settings_youtube_client_secret" class="block text-xs font-semibold mb-0.5">Client Secret</label>
      <input type="password" name="settings[youtube_client_secret]" id="settings_youtube_client_secret"
             value="<%= @settings['youtube_client_secret'] %>" autocomplete="off">
    </div>

    <div class="mb-2">
      <label for="settings_youtube_redirect_uri" class="block text-xs font-semibold mb-0.5">Redirect URI</label>
      <input type="text" name="settings[youtube_redirect_uri]" id="settings_youtube_redirect_uri"
             value="<%= @settings['youtube_redirect_uri'] %>" autocomplete="off">
    </div>
  </fieldset>

  <button type="submit">Save</button>
<% end %>
