<% content_for(:title, "settings") %>
<h1>settings</h1>
<script>
  // Sync localStorage + theme with server setting after form save
  (function() {
    var theme = "<%= (AppSetting.get('theme') || 'auto').gsub('"', '') %>";
    if (theme === "auto") {
      localStorage.removeItem("pito-theme");
    } else {
      localStorage.setItem("pito-theme", theme);
    }
    var effective = theme;
    if (theme === "auto") {
      effective = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    document.documentElement.setAttribute("data-theme", effective);
    document.documentElement.dataset.themePreference = theme;
    var label = document.querySelector('[data-theme-target="label"]');
    if (label) label.textContent = effective === "dark" ? "light" : "dark";
    if (window.recolorCharts) setTimeout(window.recolorCharts, 100);
  })();
</script>

<%# 2026-05-10 user-locked restructure — three titled sections, each a
    2-column grid:

      ## customize
      [ ui / ux ]              [ workspaces ]
      [ user ]                 [ time zone ]

      ## integrations
      [ YouTube ]              [ Voyage.ai ]
      [ OAuth applications ]   [ sessions ]

      ## stack
      [ sql ]                  [ search ]
      [ storage ]              (empty right cell)

    Section headings use the standard h2 styling. Each section holds
    its own group of `.pane-row` flex containers. Slack + Discord
    panes are deliberately NOT on this page — their controllers /
    routes / partials remain so the partial-level view specs and the
    request specs for the webhook controllers keep passing, but they
    no longer surface on the settings index per the user-locked
    layout.

    Pane h2 brand-casing rule survives the restructure: `YouTube`,
    `Voyage.ai`, `OAuth applications` keep their casing; everything
    else stays lowercase.

    YouTube credentials status — the row labels read
    `public API key` / `OAuth client ID` / `OAuth client secret` /
    `OAuth redirect URI`. The controller looks them up under the
    `:google_oauth` credentials block (NOT `:youtube` — that block
    does not exist in this install).
%>

<%# ============================================================
    customize
============================================================ %>
<h2>customize</h2>

<%# customize row 1 — ui / ux | workspaces. The section identifier on
    the wire stays `appearance` for backward compatibility with any
    scripted PATCH callers; only the visible H2 + the row label changed
    when keyboard navigation joined the pane. %>
<div class="pane-row">
  <%# ui / ux %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="appearance">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>ui / ux</h2></legend>

        <div style="margin-bottom: 6px;">
          <label class="form-label">theme</label>
          <div style="display: flex; gap: 12px;">
            <% %w[light dark auto].each do |opt| %>
              <label class="md-radio">
                <input type="radio" name="settings[theme]" value="<%= opt %>" <%= "checked" if @theme == opt %>>
                <span class="md-radio-indicator"></span>
                <span class="md-radio-label"><%= opt %><%= " (system)" if opt == "auto" %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Keyboard-navigation toggle. Renders as on / off radios so
            the row mirrors the theme picker visually. Wire format is
            yes / no per the project's external-boolean rule
            (CLAUDE.md hard rules); the controller flips it back to
            Boolean before storage. The setting is surfaced to the
            keyboard Stimulus controller via the body-level
            `data-keyboard-navigation-enabled` attribute (see
            application.html.erb). %>
        <div style="margin-bottom: 6px;">
          <label class="form-label">keyboard navigation</label>
          <div style="display: flex; gap: 12px;">
            <% %w[yes no].each do |opt| %>
              <label class="md-radio">
                <input type="radio" name="settings[keyboard_navigation_enabled]" value="<%= opt %>" <%= "checked" if (@keyboard_navigation_enabled ? "yes" : "no") == opt %>>
                <span class="md-radio-indicator"></span>
                <span class="md-radio-label"><%= opt == "yes" ? "on" : "off" %></span>
              </label>
            <% end %>
          </div>
        </div>

        <button type="submit">[update]</button>
      </fieldset>
    <% end %>
  </div>

  <%# workspaces %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="workspaces">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>workspaces</h2></legend>

        <div style="margin-bottom: 6px;">
          <label for="settings_pane_title_length" class="form-label">pane title truncation</label>
          <input type="number" name="settings[pane_title_length]" id="settings_pane_title_length"
                 value="<%= @settings['pane_title_length'] %>" min="6" max="50"
                 placeholder="<%= @pane_title_length_default %>" autocomplete="off"
                 style="width: 80px; text-align: right;">
          <span class="form-hint" style="display: block;">default: <%= @pane_title_length_default %> chars.</span>
        </div>

        <div style="margin-bottom: 6px;">
          <label for="settings_max_panes" class="form-label">max panes</label>
          <input type="number" name="settings[max_panes]" id="settings_max_panes"
                 value="<%= @settings['max_panes'] %>" min="1" max="10"
                 placeholder="<%= @max_panes_default %>" autocomplete="off"
                 style="width: 80px; text-align: right;">
          <span class="form-hint" style="display: block;">default: <%= @max_panes_default %>.</span>
        </div>

        <button type="submit">[update]</button>
      </fieldset>
    <% end %>
  </div>
</div>

<%# customize row 2 — user | time zone. %>
<div class="pane-row">
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>user</h2></legend>

      <p><%= Current.user&.email %></p>
      <p class="text-muted">
        change your email or password.<br>
        current password is required.
      </p>

      <%= render(BracketedLinkComponent.new(label: "edit account", href: settings_user_path)) %>
    </fieldset>
  </div>

  <%# Phase 26 — 01a. Timezone foundation pane. %>
  <%= render "time_zone_pane" %>
</div>

<%# ============================================================
    integrations
============================================================ %>
<h2>integrations</h2>

<%# integrations row 1 — YouTube (read-only credentials status) |
    Voyage.ai. The YouTube pane is purely informational — secrets live
    in `Rails.application.credentials.google_oauth` (CLAUDE.md hard
    rule) and editing them happens via `rails credentials:edit`. %>
<div class="pane-row">
  <%# YouTube — read-only credentials status. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>YouTube</h2></legend>

      <p class="text-muted">
        YouTube credentials live in <code>Rails.application.credentials.google_oauth</code>.
        edit with <code>rails credentials:edit</code>.
      </p>

      <%# One row per credential. The Boolean from
          `youtube_credentials_status` flips to `configured` /
          `not configured` copy. Configured rows render in muted gray;
          missing rows render in the danger color so the gap is
          legible at a glance. The underlying value is never echoed
          back. %>
      <ul style="list-style: none; padding-left: 0; margin: 0;">
        <% @youtube_credentials.each do |label, configured| %>
          <li style="margin-bottom: 2px;">
            <span><%= label %>:</span>
            <% if configured %>
              <span class="text-muted">configured</span>
            <% else %>
              <span class="text-danger">not configured</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </fieldset>
  </div>

  <%# Voyage.ai — API key + per-target indexing flags. %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="voyage">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>Voyage.ai</h2></legend>

        <div style="margin-bottom: 6px;">
          <label for="settings_voyage_api_key" class="form-label">API key</label>
          <input type="password" name="settings[voyage_api_key]" id="settings_voyage_api_key"
                 value="" autocomplete="off"
                 placeholder="<%= @voyage_configured ? 'key configured (•••••••)' : 'no key configured' %>"
                 style="max-width: 420px; width: 100%;">
          <% if @voyage_configured %>
            <span class="form-hint" style="display: block;">leave blank to keep current; submit to replace.</span>
          <% else %>
            <span class="form-hint" style="display: block;">paste your Voyage.ai API key.</span>
          <% end %>
        </div>

        <% if @voyage_configured %>
          <div style="margin-bottom: 6px;">
            <label class="md-check">
              <input type="checkbox" name="settings[clear_voyage_api_key]" value="yes">
              <span class="md-check-indicator"></span>
              <span class="md-check-label">clear stored key</span>
            </label>
            <div class="form-hint">disables Voyage.ai indexing if any flag is on.</div>
          </div>
        <% end %>

        <% if AppSetting.voyage_configured? %>
          <div style="margin-bottom: 6px;">
            <label class="form-label">indexes</label>
            <div style="display: flex; align-items: baseline; gap: 12px;">
              <span class="text-muted">project notes</span>
              <% %w[yes no].each do |opt| %>
                <label class="md-radio">
                  <input type="radio" name="settings[voyage_index_project_notes]" value="<%= opt %>" <%= "checked" if (@voyage_indexing_project_notes ? "yes" : "no") == opt %>>
                  <span class="md-radio-indicator"></span>
                  <span class="md-radio-label"><%= opt %></span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>

        <button type="submit">[update]</button>
      </fieldset>
    <% end %>
  </div>
</div>

<%# integrations row 2 — OAuth applications (+ tokens via hairline) |
    sessions. The OAuth pane keeps the combined OAuth-applications +
    tokens sub-sections fenced by a `<hr class="hairline">` so the
    two related token-issuance surfaces stay near each other in one
    cell. %>
<div class="pane-row">
  <%# Combined OAuth applications + tokens. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>OAuth applications</h2></legend>

      <p>
        <% if @oauth_applications_count.zero? %>
          no OAuth applications
        <% elsif @oauth_applications_count == 1 %>
          1 OAuth application
        <% else %>
          <%= number_with_delimiter(@oauth_applications_count) %> OAuth applications
        <% end %>
      </p>
      <p class="text-muted">
        applications that issue access tokens via authorization code + PKCE.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage applications", href: settings_oauth_applications_path)) %>
    </fieldset>

    <hr class="hairline">

    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>tokens</h2></legend>

      <p>
        <% if @active_tokens_count.zero? && @revoked_tokens_count.zero? %>
          no active tokens
        <% else %>
          <%
            active_label = @active_tokens_count == 1 ? "1 active token" :
              "#{number_with_delimiter(@active_tokens_count)} active tokens"
            active_label = "no active tokens" if @active_tokens_count.zero?
          %>
          <% if @revoked_tokens_count.positive? %>
            <%= @active_tokens_count.zero? ? "0 active" : "#{number_with_delimiter(@active_tokens_count)} active" %>
            ·
            <%= number_with_delimiter(@revoked_tokens_count) %> revoked
          <% else %>
            <%= active_label %>
          <% end %>
        <% end %>
      </p>
      <p class="text-muted">
        bearer tokens for the JSON API and MCP HTTP transport.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage tokens", href: settings_tokens_path)) %>
    </fieldset>
  </div>

  <%# sessions — active browser logins. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>sessions</h2></legend>

      <p>
        <% if @active_sessions_count.zero? %>
          no active sessions
        <% elsif @active_sessions_count == 1 %>
          1 active session
        <% else %>
          <%= number_with_delimiter(@active_sessions_count) %> active sessions
        <% end %>
      </p>
      <p class="text-muted">
        one row per active browser login.<br>
        revoke remotely from anywhere.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage sessions", href: settings_sessions_path)) %>
    </fieldset>
  </div>
</div>

<%# ============================================================
    stack
============================================================ %>
<h2>stack</h2>

<%# stack row 1 — sql | search. The sql pane reads connectivity +
    Postgres version + database name out of the ActiveRecord
    connection pool. The search pane surfaces Meilisearch health +
    indexed-document counts AND the Voyage embeddings indexing flags
    (project notes today; more targets as they ship). %>
<div class="pane-row">
  <%# sql — Postgres status. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>sql</h2></legend>

      <div style="margin-bottom: 6px;">
        <span>Postgres</span>
        <% if @postgres_status[:connected] %>
          <span style="color: var(--color-success);">▲ connected</span>
        <% else %>
          <span class="text-danger">▽ disconnected</span>
        <% end %>
      </div>

      <% if @postgres_status[:connected] %>
        <div style="margin-bottom: 6px;">
          <% if @postgres_status[:version].present? %>
            <span class="text-muted">version: <%= @postgres_status[:version] %></span><br>
          <% end %>
          <% if @postgres_status[:database].present? %>
            <span class="text-muted">database: <%= @postgres_status[:database] %></span>
          <% end %>
        </div>
      <% end %>
    </fieldset>
  </div>

  <%# search — Meilisearch + Voyage embeddings status. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>search</h2></legend>

      <div style="margin-bottom: 6px;">
        <span>Meilisearch</span>
        <% if @search_healthy %>
          <span style="color: var(--color-success);">▲ connected</span>
        <% else %>
          <span class="text-danger">▽ disconnected</span>
        <% end %>
      </div>

      <% if @search_stats.any? %>
        <div style="margin-bottom: 6px;">
          <label class="form-label">indexed documents</label>
          <% @search_stats.each do |index_name, count| %>
            <% next if index_name.end_with?("_test") %>
            <% display_name = index_name.sub(/_(development|production)\z/, "") %>
            <span class="text-muted"><%= display_name %>: <%= number_with_delimiter(count) %></span><br>
          <% end %>
        </div>
      <% end %>

      <%# Voyage embeddings status — read out of AppSetting so the
          search pane shows the full hybrid-search picture (keyword
          via Meilisearch + semantic via Voyage). The API key
          itself stays in the Voyage.ai pane (integrations); this
          row is pure status. %>
      <div style="margin-bottom: 6px;">
        <span>Voyage embeddings</span>
        <% if @voyage_configured %>
          <span style="color: var(--color-success);">▲ configured</span>
        <% else %>
          <span class="text-danger">▽ not configured</span>
        <% end %>
        <% if @voyage_configured %>
          <br>
          <span class="text-muted">project notes: <%= @voyage_indexing_project_notes ? "indexing" : "off" %></span>
        <% end %>
      </div>

      <%= render(BracketedLinkComponent.new(
        label: "reindex",
        href: "#",
        data: {
          controller: "modal-trigger",
          action: "click->modal-trigger#open",
          modal_trigger_target_id_value: "reindex_meilisearch_modal"
        }
      )) %>
      <%= render(ConfirmModalComponent.new(
        id: "reindex_meilisearch_modal",
        title: "reindex Meilisearch?",
        body: "this re-indexes all configured targets. it can take a while on large corpora and adds load to the search service.",
        confirm_path: settings_reindex_path,
        confirm_method: :post,
        confirm_label: "reindex",
        cancel_label: "cancel",
        destructive: false
      )) %>
    </fieldset>
  </div>
</div>

<%# stack row 2 — storage | (empty right cell). The right slot stays
    empty by design; the locked layout puts `storage` as the last
    pane and leaves its row partner blank. %>
<div class="pane-row">
  <%# storage — pito-assets volume status. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>storage</h2></legend>

      <div style="margin-bottom: 6px;">
        <span>pito-assets</span>
        <% if @storage_status[:present] %>
          <% if @storage_status[:writable] %>
            <span style="color: var(--color-success);">▲ writable</span>
          <% else %>
            <span class="text-danger">▽ read-only</span>
          <% end %>
        <% else %>
          <span class="text-muted">▽ not present</span>
        <% end %>
      </div>

      <% if @storage_status[:path].present? %>
        <div style="margin-bottom: 6px;">
          <span class="text-muted">path: <code><%= @storage_status[:path] %></code></span>
        </div>
      <% end %>

      <p class="text-muted">
        on-disk home for footage thumbnails and Active Storage blobs.
      </p>
    </fieldset>
  </div>
</div>
