<% content_for(:title, "revoke session") %>
<% breadcrumb(["settings", settings_path], ["sessions", settings_sessions_path], "revoke") %>

<div style="margin-bottom: 8px;">
  <h1>revoke session</h1>
  <p class="text-muted" style="margin-top: 2px;">
    this sets <code>revoked_at</code> on the row. the browser holding this
    session is signed out on its next request. the row stays in the database
    for the audit trail.
  </p>
</div>

<table class="detail-table" style="margin-bottom: 12px;">
  <tr>
    <td class="text-muted">user-agent</td>
    <td><code><%= @session.user_agent.presence || "—" %></code></td>
  </tr>
  <tr>
    <td class="text-muted">ip</td>
    <td><%= @session.ip || "—" %></td>
  </tr>
  <tr>
    <td class="text-muted">last activity</td>
    <td>
      <% if @session.last_activity_at %>
        <%= @session.last_activity_at.strftime("%Y-%m-%d %H:%M") %>
      <% else %>
        never
      <% end %>
    </td>
  </tr>
  <tr>
    <td class="text-muted">remember</td>
    <td><%= @session.remember? ? "yes" : "no" %></td>
  </tr>
  <% if @session.current? %>
    <tr>
      <td class="text-muted">note</td>
      <td><strong>this is your current session.</strong> revoking it signs you out.</td>
    </tr>
  <% end %>
</table>

<%= render "shared/action_screen",
  submit_label: "[revoke]",
  cancel_path: settings_sessions_path,
  form_url: settings_session_path(@session),
  form_method: :delete,
  destructive: true %>
