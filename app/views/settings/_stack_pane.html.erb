<%# Phase 29 (settings refactor) — row 3 stack pane (spans both columns
    via `.pane--wide`).

    Two-column inner layout:
      left  — `db` (Postgres + Redis breakdowns)
      right — `search` (Meilisearch + Voyage embeddings) + `storage`
              (assets + notes) stacked.

    Reuses the same ivars + helpers the prior settings index relied
    on (`@postgres_status`, `@redis_status`,
    `@search_per_index_stats`, `@postgres_table_breakdown`,
    `@sidekiq_breakdown`, `@storage_status`, `@notes_volume_status`,
    `@assets_breakdown`, `@notes_breakdown`, `@voyage_configured`,
    `@search_healthy`).

    Every breakdown table renders as `table.stack-table` (see
    `application.css`). The class pins width: 100%, drops borders /
    zebra, and zeroes left padding on the first column + right
    padding on the last column so the five tables share the same
    left/right edges across the pane. Numeric columns use `.num` for
    right alignment + tabular figures; combined with class-driven
    padding the header and the value share the same right edge.
    Sizes use `human_filesize_int` for integer-only, KB-minimum
    output. %>
<div class="pane pane--wide">
  <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
    <legend><h2>stack</h2></legend>

    <div style="display: grid; grid-template-columns: 1fr 1px 1fr; gap: 12px; align-items: stretch;">
      <%# Left column: db (Postgres + Redis with hairline) %>
      <div>
        <div style="margin-bottom: 6px;">
          <span><strong>Postgres</strong></span>
          <% if @postgres_status[:connected] %>
            <span style="color: var(--color-success);">▲ connected</span>
          <% else %>
            <span class="text-danger">▽ disconnected</span>
          <% end %>
        </div>

        <% if @postgres_status[:connected] && @postgres_table_breakdown.any? %>
          <div data-controller="sortable-table" data-sortable-table-id-value="stack-postgres">
            <table class="stack-table" style="margin-bottom: 8px;" data-sortable-table-target="table">
              <thead>
                <tr>
                  <%= render(SortableHeaderComponent.new(label: "model", sort_type: "string")) %>
                  <%= render(SortableHeaderComponent.new(label: "rows", sort_type: "number", numeric: true)) %>
                  <%= render(SortableHeaderComponent.new(label: "size", sort_type: "number", numeric: true)) %>
                </tr>
              </thead>
              <tbody>
                <% @postgres_table_breakdown.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="num">
                      <span data-sort-value="<%= row[:count] || -1 %>">
                        <%= row[:count] ? number_with_delimiter(row[:count]) : "—" %>
                      </span>
                    </td>
                    <td class="num">
                      <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                        <%= human_filesize_int(row[:size_bytes]) %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>

        <hr class="hairline">

        <div style="margin-bottom: 6px;">
          <span><strong>Redis</strong></span>
          <% if @redis_status[:connected] %>
            <span style="color: var(--color-success);">▲ connected</span>
          <% else %>
            <span class="text-danger">▽ disconnected</span>
          <% end %>
        </div>

        <% if @redis_status[:connected] && @sidekiq_breakdown.any? %>
          <%
            sidekiq_counts = @sidekiq_breakdown.each_with_object({}) do |row, acc|
              acc[row[:label]] = row[:count]
            end
          %>
          <%# Sidekiq breakdown — two semantic groupings (lifetime
              counters: successful / failed; queue counters: busy /
              scheduled / enqueued / retry / dead) rendered as one
              5-column `.stack-table` so every cell shares the
              pane's right edge with the other stack tables. The
              lifetime row uses colspan 3 + 2 to split the 5
              columns into a 60/40 group; the queue row uses one
              column each. Numeric headers + cells use `.num`
              for right alignment + tabular figures. %>
          <table class="stack-table" style="margin-bottom: 8px;">
            <thead>
              <tr>
                <th class="num" colspan="3">successful</th>
                <th class="num" colspan="2">failed</th>
              </tr>
              <tr>
                <td class="num" colspan="3">
                  <%= sidekiq_counts["processed"] ? number_with_delimiter(sidekiq_counts["processed"]) : "—" %>
                </td>
                <td class="num" colspan="2">
                  <%= sidekiq_counts["failed"] ? number_with_delimiter(sidekiq_counts["failed"]) : "—" %>
                </td>
              </tr>
              <tr>
                <th class="num">busy</th>
                <th class="num">scheduled</th>
                <th class="num">enqueued</th>
                <th class="num">retry</th>
                <th class="num">dead</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <% %w[busy scheduled enqueued retry dead].each do |state| %>
                  <td class="num">
                    <%= sidekiq_counts[state] ? number_with_delimiter(sidekiq_counts[state]) : "—" %>
                  </td>
                <% end %>
              </tr>
            </tbody>
          </table>
        <% end %>
      </div>

      <div style="background: var(--color-border); width: 1px;"></div>

      <%# Right column: search + storage stacked %>
      <div>
        <div style="margin-bottom: 6px;">
          <span><strong>Meilisearch</strong></span>
          <% if @search_healthy %>
            <span style="color: var(--color-success);">▲ connected</span>
          <% else %>
            <span class="text-danger">▽ disconnected</span>
          <% end %>
        </div>

        <% if @search_per_index_stats.any? %>
          <div data-controller="sortable-table" data-sortable-table-id-value="stack-meilisearch">
            <table class="stack-table" style="margin-bottom: 8px;" data-sortable-table-target="table">
              <thead>
                <tr>
                  <%= render(SortableHeaderComponent.new(label: "index", sort_type: "string")) %>
                  <%= render(SortableHeaderComponent.new(label: "docs", sort_type: "number", numeric: true)) %>
                  <%= render(SortableHeaderComponent.new(label: "size", sort_type: "number", numeric: true)) %>
                </tr>
              </thead>
              <tbody>
                <% @search_per_index_stats.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="num">
                      <span data-sort-value="<%= row[:documents].to_i %>">
                        <%= number_with_delimiter(row[:documents].to_i) %>
                      </span>
                    </td>
                    <td class="num">
                      <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                        <%= human_filesize_int(row[:size_bytes]) %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>

        <hr class="hairline">

        <%# Phase 32 follow-up (2026-05-16) — Voyage section extracted
            so `ReindexAllJob` can swap it via Turbo Stream replace
            without re-rendering the entire stack pane. The
            subscription below mounts the `reindex_status` stream;
            the job broadcasts to it from its `ensure` block when
            the reindex completes (or crashes).

            The `[reindex]` confirm modal is rendered HERE, outside
            the `<div id="voyage_section">` broadcast target, on
            purpose. The job's `broadcast_replace_to` runs in a
            JOB context with no `request` / `session`, so any
            `form_with` rendered inside the broadcast target would
            bake a hidden `authenticity_token` unbound to any user's
            session — the next submit hits
            `ActionController::InvalidAuthenticityToken`. Mounting
            the modal at page-render time gives it a CSRF token
            bound to the current session that stays valid across
            broadcast-driven state flips of the trigger link.
            See the matching note in `_voyage_section.html.erb`. %>
        <%= turbo_stream_from "reindex_status" %>
        <%= render "voyage_section" %>
        <%= render(ConfirmModalComponent.new(
          id: "reindex_meilisearch_modal",
          title: "reindex Meilisearch?",
          body: "this re-indexes all configured targets.",
          confirm_path: settings_reindex_path,
          confirm_method: :post,
          confirm_label: "reindex",
          cancel_label: "cancel",
          destructive: true
        )) %>

        <hr class="hairline">

        <div style="margin-bottom: 6px;">
          <span><strong>assets</strong></span>
          <% if @storage_status[:present] %>
            <% if @storage_status[:writable] %>
              <span style="color: var(--color-success);">▲ writable</span>
            <% else %>
              <span class="text-danger">▽ read-only</span>
            <% end %>
          <% else %>
            <span class="text-muted">▽ not present</span>
          <% end %>
        </div>

        <% if @assets_breakdown.any? %>
          <div data-controller="sortable-table" data-sortable-table-id-value="stack-assets">
            <table class="stack-table" style="margin-bottom: 8px;" data-sortable-table-target="table">
              <thead>
                <tr>
                  <%= render(SortableHeaderComponent.new(label: "category", sort_type: "string")) %>
                  <%= render(SortableHeaderComponent.new(label: "files", sort_type: "number", numeric: true)) %>
                  <%= render(SortableHeaderComponent.new(label: "size", sort_type: "number", numeric: true)) %>
                </tr>
              </thead>
              <tbody>
                <% @assets_breakdown.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="num">
                      <span data-sort-value="<%= row[:file_count] || -1 %>">
                        <%= row[:file_count] ? number_with_delimiter(row[:file_count]) : "—" %>
                      </span>
                    </td>
                    <td class="num">
                      <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                        <%= human_filesize_int(row[:size_bytes]) %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>

        <hr class="hairline">

        <div style="margin-bottom: 6px;">
          <span><strong>notes</strong></span>
          <% if @notes_volume_status[:present] %>
            <% if @notes_volume_status[:writable] %>
              <span style="color: var(--color-success);">▲ writable</span>
            <% else %>
              <span class="text-danger">▽ read-only</span>
            <% end %>
          <% else %>
            <span class="text-muted">▽ not present</span>
          <% end %>
        </div>

        <% if @notes_breakdown.any? %>
          <div data-controller="sortable-table" data-sortable-table-id-value="stack-notes">
            <table class="stack-table" style="margin-bottom: 8px;" data-sortable-table-target="table">
              <thead>
                <tr>
                  <%= render(SortableHeaderComponent.new(label: "namespace", sort_type: "string")) %>
                  <%= render(SortableHeaderComponent.new(label: "count", sort_type: "number", numeric: true)) %>
                  <%= render(SortableHeaderComponent.new(label: "size", sort_type: "number", numeric: true)) %>
                </tr>
              </thead>
              <tbody>
                <% @notes_breakdown.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="num">
                      <span data-sort-value="<%= row[:count] || -1 %>">
                        <%= row[:count] ? number_with_delimiter(row[:count]) : "—" %>
                      </span>
                    </td>
                    <td class="num">
                      <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                        <%= human_filesize_int(row[:size_bytes]) %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </fieldset>
</div>
