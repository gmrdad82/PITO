<% content_for(:title, "security") %>
<% breadcrumb(["settings", settings_path], "security") %>

<div style="margin-bottom: 8px;">
  <h1>security</h1>
</div>

<div class="pane pane--standalone" style="margin-bottom: 12px;">
  <h2 style="margin-top: 0;">2FA</h2>
  <%# Phase 32 follow-up (2026-05-16) — 2FA / TOTP cleanup.
      The web-side manage surface (disable + backup-code rotation) is
      gone; both moved to operator-only rake tasks
      (`pito:user:reset_totp`, `pito:user:regenerate_backup_codes`).
      The status line stays here as read-only context. %>
  <p class="text-muted" style="margin-top: 2px;">
    status:
    <% if @twofa_enabled %>
      <strong>on</strong>
    <% else %>
      <strong>off</strong>
    <% end %>
  </p>
</div>
