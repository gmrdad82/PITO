<%# Phase 29 (settings refactor) — settings security modal.

    A layout-positioned `<dialog>` with a `<turbo-frame>` inside; the
    `settings-modal` Stimulus controller wraps the dialog and swaps the
    target URL into the frame's `src` on open. Mirrors the
    `notification-modal` / `calendar-entry-modal` pattern.

    Each link that opens this modal carries:
      - `href`           — the canonical standalone URL (JS-off fallback).
      - `data-action`    — `click->settings-modal#open`.
      - optional `data-settings-modal-title-param` for the header.

    The standalone settings views (`/settings/security/totp`,
    `/settings/sessions`, `/settings/security/blocks`) are also wrapped
    in a matching `<turbo-frame id="settings_modal_frame">` so the
    server response slots into this frame cleanly.

    The inner wrapper has no max-width cap; the dialog's own 960px cap
    (in `application.css`) bounds the content. %>
<dialog data-settings-modal-target="dialog"
        data-action="click->settings-modal#clickOutside cancel->settings-modal#cancelDismiss"
        class="pane-dialog settings-modal">
  <div style="padding: 12px 16px; min-width: 0; width: 100%; max-width: none; max-height: 80vh; overflow-y: auto;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
      <h2 data-settings-modal-target="title" style="margin: 0;"><%= raw("&nbsp;") %></h2>
      <%= render(BracketedLinkComponent.new(label: t("common.actions.close"), href: "#",
          data: { action: "click->settings-modal#close" })) %>
    </div>
    <%# 2026-05-16 — inline `display: block; width: 100%` as a safety
        net alongside the global `turbo-frame { display: block }` rule
        in `app/assets/tailwind/application.css`. Custom elements
        default to `display: inline`, which shrinks the frame to its
        children's min-content and collapses the inner pane-row to
        one pane wide. The CSS rule is the proper fix; the inline
        style guarantees correct layout even if the rule is missed
        (specificity collision, build cache, etc.). %>
    <%= turbo_frame_tag "settings_modal_frame",
                        style: "display: block; width: 100%;",
                        data: { settings_modal_target: "frame" } %>
  </div>
</dialog>
