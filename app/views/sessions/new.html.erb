<% content_for(:title, "log in") %>
<% content_for(:hide_chrome, true) %>

<div style="max-width: 420px; margin: 24px 0;">
  <h1>log in</h1>

  <%= form_with url: login_path, method: :post, scope: nil,
                data: { turbo: false } do %>
    <div style="margin-bottom: 12px;">
      <label for="login_username" class="form-label">username</label>
      <input type="text" name="username" id="login_username"
             value="<%= @username %>" required autocomplete="username"
             style="width: 100%;">
    </div>

    <div style="margin-bottom: 12px;">
      <label for="login_password" class="form-label">password</label>
      <input type="password" name="password" id="login_password"
             required autocomplete="current-password"
             style="width: 100%;">
    </div>

    <div class="dot-list">
      <button type="submit">[log in]</button>
      <%# 2026-05-16 — middle-dot separator between `[log in]` and
          `[reset password]`, matching the `nav-sep` pattern from the
          channel show page and the Discord/Slack settings panes
          (between `[update]` and `[help]`). %>
      <span class="nav-sep" aria-hidden="true">·</span>
      <%= render(BracketedLinkComponent.new(label: "reset password", href: password_reset_path)) %>
    </div>
  <% end %>
</div>
