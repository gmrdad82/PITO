<%# Phase 27 — 01d. Display mode switcher.
    Three `button_to` forms PATCHing `/users/games_preferences` with
    `mode=grid|list|shelves_by_letter`. No JS — pure form posts. The
    controller redirects back to `/games?display=<mode>` so the
    resolved mode renders immediately AND the user's preference
    persists for fresh-tab visits.

    Active mode renders with the `active` class (no red — the
    bracketed-link convention reserves red for destructive actions).

    Renders top-right of `/games`, above the filter row.

    Locals:
      active_mode  Symbol — one of :grid, :list, :shelves_by_letter.
%>
<%
  modes = [
    [ :grid, "grid" ],
    [ :list, "list" ],
    [ :shelves_by_letter, "shelves" ]
  ]
%>
<div class="display-mode-switcher"
     data-active-mode="<%= active_mode %>"
     style="display: inline-flex; gap: 4px; align-items: baseline;">
  <% modes.each do |mode_key, mode_label| %>
    <% is_active = (active_mode.to_sym == mode_key) %>
    <%= button_to users_games_preferences_path,
                  params: { mode: mode_key.to_s },
                  method: :patch,
                  form: { style: "display: inline;", data: { turbo: false } },
                  class: ("bracketed" + (is_active ? " active" : "")),
                  data: { display_mode: mode_key.to_s } do %>
      [<span class="bl"><%= mode_label %></span>]
    <% end %>
  <% end %>
</div>
