<%# 2026-05-18 — `:games_search` omnisearch results partial.

    Locals:
      result  — Games::SearchService::Result struct
      query   — sanitized query string

    Three sections (in display order):
      1. local games — click row navigates to /games/:slug.
      2. local bundles — click row navigates to /bundles/:slug.
      3. IGDB games — click row navigates to the IGDB add flow
         (`/games?new=<igdb_id>` style — actually we surface a
         small `[add]` action that POSTs `/games` with the igdb_id
         + title pre-seed, identical to the `:game_index` row
         contract).

    Each section is its own subgroup with a small `kind` label
    header. Empty sections are hidden. When the query is blank, the
    body renders a hint.

    2026-05-18 — section chrome (heading + hairline + empty copy +
    `<ul>`/`<li>` wrappers) is delegated to the shared
    `shared/search_section` partial so future surfaces
    (`/projects`, `/videos`, `/channels`) reuse it. The per-row
    markup stays here. %>
<%= turbo_frame_tag "omnisearch_results_games_search" do %>
  <% if query.blank? %>
    <p class="text-muted"><%= t("games.omnisearch.placeholder_default") %></p>
  <% else %>
    <% has_local_games = result.local_games.any? %>
    <% has_local_bundles = result.local_bundles.any? %>
    <% has_igdb = result.igdb.any? || result.igdb_error.present? %>

    <% if has_local_games %>
      <%= render "shared/search_section",
                 heading: t("games.omnisearch.section_games"),
                 items: result.local_games,
                 empty_copy: t("games.omnisearch.no_results", query: query),
                 first: true do |game| %>
        <%= link_to game_path(game),
                    data: { turbo_frame: "_top" },
                    style: "flex: 1; text-decoration: none; color: inherit;" do %>
          <%= game.title %>
          <% if game.release_year %>
            <span class="text-muted">(<%= game.release_year %>)</span>
          <% end %>
        <% end %>
        <span class="text-muted" style="font-size: 11px;"><%= t("games.omnisearch.row_kind_game") %></span>
      <% end %>
    <% end %>

    <% if has_local_bundles %>
      <%= render "shared/search_section",
                 heading: t("games.omnisearch.section_bundles"),
                 items: result.local_bundles,
                 empty_copy: t("games.omnisearch.no_results", query: query),
                 first: !has_local_games do |bundle| %>
        <%= link_to bundle_path(bundle),
                    data: { turbo_frame: "_top" },
                    style: "flex: 1; text-decoration: none; color: inherit;" do %>
          <%= bundle.name %>
        <% end %>
        <span class="text-muted" style="font-size: 11px;"><%= t("games.omnisearch.row_kind_bundle") %></span>
      <% end %>
    <% end %>

    <% if has_igdb %>
      <% if result.igdb_error.present? %>
        <%# 2026-05-18 — bespoke error variant of the IGDB section; the
            error paragraph is `text-danger`, which doesn't fit the
            shared partial's `text-muted` empty-state contract. We
            hand-render the section chrome here for this case only. %>
        <% unless has_local_games || has_local_bundles %>
          <% # first section: no leading hairline %>
        <% else %>
          <hr class="hairline" style="margin: 12px 0;">
        <% end %>
        <section class="omnisearch-section">
          <h3 class="omnisearch-section-heading"><%= t("games.omnisearch.section_igdb") %></h3>
          <p class="text-danger"><%= t("games.omnisearch.igdb_error", msg: result.igdb_error[:message]) %></p>
        </section>
      <% else %>
        <%
          result_igdb_ids = result.igdb.map { |row| row["id"] }.compact
          existing_games_by_igdb_id = Game.where(igdb_id: result_igdb_ids).index_by(&:igdb_id)
        %>
        <%= render "shared/search_section",
                   heading: t("games.omnisearch.section_igdb"),
                   items: result.igdb,
                   empty_copy: t("games.omnisearch.no_igdb_results", query: query),
                   first: !(has_local_games || has_local_bundles) do |row| %>
          <% release_year = row["first_release_date"].present? ? Time.at(row["first_release_date"]).utc.year : nil %>
          <% existing = existing_games_by_igdb_id[row["id"]] %>
          <span style="flex: 1;">
            <%= row["name"] %>
            <% if release_year %>
              <span class="text-muted">(<%= release_year %>)</span>
            <% end %>
          </span>
          <% if existing %>
            <%= link_to game_path(existing),
                        class: "bracketed",
                        data: { turbo_frame: "_top" } do %>[<span class="bl"><%= t("common.actions.open") %></span>]<% end %>
          <% else %>
            <%= button_to games_path,
                          params: { game: { igdb_id: row["id"], title: row["name"] } },
                          method: :post,
                          class: "bracketed",
                          form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl"><%= t("common.actions.add") %></span>]<% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <% if result.local_games.empty? && result.local_bundles.empty? && result.igdb.empty? && result.igdb_error.blank? %>
      <p class="text-muted"><%= t("games.omnisearch.no_results", query: query) %></p>
    <% end %>
  <% end %>
<% end %>
