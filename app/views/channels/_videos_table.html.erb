<%# 2026-05-11 channel show restructure — videos block.
    Replaces the prior `_videos_pane` (a pane wrapper with a stripped
    sortable table). The block is no longer a pane: it is a top-level
    table that mirrors /videos' column shape. Capped at 30 rows,
    starred-first then latest by COALESCE(published_at, created_at) DESC.
    Channel column is omitted (everything here is the same channel).

    Required locals (passed in from `channels/show.html.erb`):
      channel — the Channel record
      videos  — the AR relation already aggregated + ordered + limited
      total   — total count of videos on this channel (for the [see all] gate)
%>
<div style="margin-top: 16px;">
  <div class="dot-list" style="margin-bottom: 6px;">
    <h2 style="display: inline; margin: 0;">videos (<%= number_with_delimiter(total) %>)</h2>
    <%# R2 (2026-05-25) — /videos screen removed; "see all" link dropped. %>
  </div>

  <% if videos.any? %>
    <div class="themed-scroll-x" style="overflow-x: auto; max-width: 100%;">
      <table style="table-layout: fixed; width: 980px;">
        <colgroup>
          <col style="width: 60px;">  <%# id %>
          <col style="width: 160px;"> <%# youtube id %>
          <col style="width: 240px;"> <%# title %>
          <col style="width: 80px;">  <%# privacy %>
          <col style="width: 80px;">  <%# views %>
          <col style="width: 80px;">  <%# likes %>
          <col style="width: 80px;">  <%# chats %>
          <col style="width: 80px;">  <%# watch %>
          <col style="width: 60px;">  <%# star %>
          <col style="width: 100px;"> <%# synced %>
          <col style="width: 60px;">  <%# edit %>
        </colgroup>
        <thead>
          <tr>
            <th>id</th>
            <th>YouTube id</th>
            <th>title</th>
            <th>privacy</th>
            <th class="num">views</th>
            <th class="num">likes</th>
            <th class="num">chats</th>
            <th class="num">watch</th>
            <th class="num">star</th>
            <th class="num">synced</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% videos.each do |video| %>
            <tr>
              <td><%= link_to video.id, video_path(video), data: { turbo_frame: "_top" } %></td>
              <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= video.youtube_video_id %>"><%= video.youtube_video_id %></td>
              <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= video.title %>"><%= video.title.presence || "untitled" %></td>
              <td>
                <%= video.privacy_status %>
                <% if video.imported? %>
                  <span class="text-muted" style="font-size: 11px;">imported</span>
                <% end %>
              </td>
              <td class="num"><%= number_with_delimiter(video.total_views) %></td>
              <td class="num"><%= number_with_delimiter(video.total_likes) %></td>
              <td class="num"><%= number_with_delimiter(video.total_comments) %></td>
              <td class="num"><span data-sort-value="<%= video.total_watch_time.to_i %>"><%= format_video_watch_time(video.total_watch_time) %></span></td>
              <td class="num"><%= video.star? ? "yes" : "no" %></td>
              <td class="num">
                <% if video.last_synced_at.present? %>
                  <%= compact_time_ago(video.last_synced_at) %>
                <% else %>
                  —
                <% end %>
              </td>
              <td><%# R2 — edit action removed with /videos screen %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">no videos yet.</p>
  <% end %>
</div>
