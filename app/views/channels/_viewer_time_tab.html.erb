<%#
  Phase 26 §01g — viewer-time heatmap on the per-channel analytics
  dashboard. Aggregates every video on the channel via the rollup
  service, in the authenticated user's timezone.
%>
<section class="analytics-section analytics-viewer-time" style="margin: 16px 0;">
  <h2>viewer-time heatmap</h2>
  <% rollup = Pito::Analytics::ViewerTimeRollup.new.call(
       scope: :channel,
       id: channel.id,
       tz: "Etc/UTC"
     ) %>
  <%= render(ViewerTimeHeatmapComponent.new(
        data: rollup,
        tz: "Etc/UTC"
      )) %>
</section>
