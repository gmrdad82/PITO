<% content_for(:title, "search") %>
<% content_for(:breadcrumbs) do %>
  <span class="text-muted">search</span>
<% end %>

<% if @query.blank? %>
  <p class="caption">enter a search query above.</p>
<% else %>
  <p class="text-muted" style="margin-bottom: 8px;">
    results for "<%= @query %>" &mdash;
    <%= number_with_delimiter(@videos[:total]) %> video<%= @videos[:total] == 1 ? "" : "s" %>
    <span class="caption" style="font-size: 11px;">(<%= number_with_delimiter(@videos[:took_ms]) %>ms)</span>
  </p>

  <%# Phase 7 Path A2 (literal full retract). Video search is a stub —
      Video declares no `searchable :*` / `filterable :*` lines, so the
      Meilisearch index for videos contains only the id column and
      query-text matching is impossible. The surface remains
      functional; it just returns zero results until Phase 8+ wires
      real metadata back in. %>
  <p class="caption">
    video search is currently disabled (Phase 7 Path A2 retract). once
    youtube sync ships and videos carry synced metadata again, this
    surface will start returning matches.
  </p>
<% end %>
