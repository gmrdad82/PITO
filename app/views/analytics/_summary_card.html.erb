<%# Phase 13.3 — Single metric summary card. Locals:
      label : human-readable metric name
      value : the metric value (nil safe)
      type  : :count | :integer | :duration_seconds | :ratio | :money
%>
<div class="analytics-summary-card"
     style="border: 1px solid var(--color-border); padding: 8px 10px; min-width: 140px;">
  <div class="caption" style="margin-bottom: 4px;"><%= label %></div>
  <div class="metric-value" style="font-size: 16px;">
    <%= format_metric(value, type: type) %>
  </div>
</div>
