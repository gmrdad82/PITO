<%# Phase 13.3 — Window picker. Four bracketed buttons; the active
    window renders inert (`bracketed-active`), the inactive ones
    are links that swap `?window=...` on the current URL.

    `current_url` local: callers pass either `analytics_path`,
    `channel_analytics_path(@channel)`, or `video_analytics_path(@video)`
    so the picker stays generic across the three dashboards. %>
<nav class="analytics-window-picker"
     style="display: flex; gap: 6px; align-items: center;"
     data-controller="analytics-window-picker"
     data-analytics-window-picker-current-value="<%= window %>">
  <% AnalyticsWindow::WINDOWS.each do |w| %>
    <% if w == window %>
      <span class="bracketed-active">[<%= analytics_window_label(w) %>]</span>
    <% else %>
      <%= link_to "[#{analytics_window_label(w)}]",
                  url_for(window: w),
                  class: "bracketed",
                  data: { analytics_window_picker_target: "button", window: w } %>
    <% end %>
  <% end %>
</nav>
