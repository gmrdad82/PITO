<%# Phase 13.3 — C3: top-videos leaderboard table. Local: `rows`
    (a relation of `TopVideosWindow` rows). Up to 50 rows per
    master-agent decision 8 (no pagination). %>
<section class="analytics-top-videos">
  <h3>top videos — <%= analytics_window_label(window, long: true) %></h3>
  <% if rows.any? %>
    <table class="analytics-leaderboard">
      <thead>
        <tr>
          <th>rank</th>
          <th>video</th>
          <th>views</th>
          <th>watch time</th>
          <th>likes</th>
        </tr>
      </thead>
      <tbody>
        <% rows.each do |row| %>
          <tr>
            <td><%= row.rank %></td>
            <td>
              <%= link_to row.video.title.presence || row.video.youtube_video_id || "video #{row.video.id}",
                          video_path(row.video) %>
            </td>
            <td><%= format_metric(row.views, type: :count) %></td>
            <td><%= format_metric(row.estimated_minutes_watched, type: :count) %> min</td>
            <td><%= format_metric(row.likes, type: :count) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
