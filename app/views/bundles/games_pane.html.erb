<%# Phase 27 follow-up (2026-05-17) — Bundle games pane (formerly the
    Collection games pane).

    Turbo Frame fragment that fills the `/games` bundles modal. Slice 3
    of the modal revamp (2026-05-17) replaces the flat wrapping grid of
    cover tiles with a CSS-positioned composite that mirrors the libvips
    composite-cover layout. Up to nine games render as percentage-
    positioned anchors over a 3:4 canvas (cells supplied by
    `Composite::CellMap.for(n)`, the same source of truth the libvips
    renderer uses — so a layout edit propagates to both surfaces for
    free). When the bundle holds more than nine games an overflow shelf
    below shows the remainder as bare `Games::CoverComponent :shelf`
    tiles inside a wheel-guarded `steam-shelf` row.

    The 1-game case falls out naturally: `Composite::CellMap.for(1)`
    returns a single cell at `(0, 0, 1, 1)` so the lone cover fills the
    canvas without a special branch here.

    Empty state: a short muted line. No JS confirm / alert / prompt.
%>
<%= turbo_frame_tag "bundles_modal_frame" do %>
  <% if @games.any? %>
    <% games = @games.limit(50) %>
    <% first_nine = games.first(9) %>
    <% overflow = games.drop(9) %>
    <% cells = Composite::CellMap.for(first_nine.size) %>

    <%# CSS composite: each game positioned per the cells map. The
        wrapper holds the 3:4 canvas (matches the libvips render
        proportions); each cell anchors to a percentage rect so the
        composite scales fluidly with the modal width.

        2026-05-17 — outer border and 2px radius live in the
        `.bundle-modal-composite` CSS rule (theme-aware via
        `--color-cover-border`, matching the shared shelf cover
        edge). `overflow: hidden` on the wrapper clips per-corner
        cell radii to the composite outline. Inline style retains
        only the per-instance positional bits. %>
    <div class="bundle-modal-composite"
         style="width: 100%; aspect-ratio: 3 / 4;">
      <% first_nine.each_with_index do |game, i| %>
        <% cell = cells[i] %>
        <% next unless cell %>
        <%# 2026-05-17 — per-corner class hooks. Composite::CellMap
            decorates each cell with a `:corners` array enumerating
            which OUTSIDE corners of the unit-square composite the
            cell touches (any of `:top_left`, `:top_right`,
            `:bottom_left`, `:bottom_right`). Map each to a short
            class suffix (`tl`/`tr`/`bl`/`br`) so only the four
            actual corner cells of the grid pick up a 2px radius
            on their outward-facing corner — edge cells (e.g.
            top-middle of a 3×3) and the center cell stay square. %>
        <% corner_classes = (cell[:corners] || []).map { |c|
             { top_left: "bundle-modal-cell--corner-tl",
               top_right: "bundle-modal-cell--corner-tr",
               bottom_left: "bundle-modal-cell--corner-bl",
               bottom_right: "bundle-modal-cell--corner-br" }[c]
           }.compact %>
        <a href="<%= game_path(game) %>"
           class="<%= (["bundle-modal-cell"] + corner_classes).join(" ") %>"
           style="position: absolute; left: <%= cell[:x] * 100 %>%; top: <%= cell[:y] * 100 %>%; width: <%= cell[:w] * 100 %>%; height: <%= cell[:h] * 100 %>%;"
           data-turbo-frame="_top"
           title="<%= game.title %>">
          <% cover_src = game.cover_master_url(fallback_size: "t_cover_big_2x") %>
          <% if cover_src %>
            <%# 2026-05-17 — prefer the normalized local master at
                `/covers/games/<id>/master.jpg` (600×800 q95). Falls back to
                IGDB `t_cover_big_2x` (528×748) for games whose master
                has not been generated yet. The overflow shelf below
                stays on `Games::CoverComponent :shelf` which already
                inherits the master-first behavior via the component. %>
            <%= image_tag cover_src,
                          alt: game.title,
                          loading: "lazy",
                          style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
          <% end %>
        </a>
      <% end %>
    </div>

    <% if overflow.any? %>
      <div class="bundle-modal-overflow" style="margin-top: 16px;">
        <h3 style="margin: 0 0 6px;">+<%= pluralize(overflow.size, "more game") %></h3>
        <hr class="hairline">
        <div class="shelf-row bundle-modal-overflow-row"
             data-controller="steam-shelf"
             data-steam-shelf-target="row"
             style="display: flex; gap: 6px; overflow-x: auto; padding-bottom: 6px; margin-top: 8px;">
          <% overflow.each do |game| %>
            <a href="<%= game_path(game) %>" data-turbo-frame="_top">
              <%= render(Games::CoverComponent.new(game: game, variant: :shelf, link_to_show: false)) %>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="text-muted">no games in this bundle yet.</p>
  <% end %>
<% end %>
