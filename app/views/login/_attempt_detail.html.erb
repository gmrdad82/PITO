<%# Phase 25 — 01b. Attempt detail card. Shared with 01c's
    notification surface — keep visual layout stable so the
    notification card and the holding page tell the same story. %>
<% if attempt %>
  <div class="pane pane--standalone" style="margin-bottom: 12px;">
    <p style="margin: 0;"><strong>attempt detail</strong></p>
    <p class="text-muted" style="margin-top: 4px;">
      browser: <strong><%= attempt.browser.presence || "unknown" %></strong>
      on <strong><%= attempt.os.presence || "unknown" %></strong><br>
      <% if attempt.geo_summary.present? %>
        location: <strong><%= attempt.geo_summary %></strong><br>
      <% end %>
      ip: <strong><%= attempt.ip %></strong><br>
      fingerprint: <code><%= attempt.fingerprint_short %></code>
    </p>
  </div>
<% end %>
