<% content_for(:title, "2FA challenge") %>
<% content_for(:hide_chrome, true) %>

<%# The form posts EITHER a 6-digit TOTP code as `code`, OR an 8-char
    backup code as `backup_code`. Two distinct param names are
    deliberate — the segmented input (`TotpCodeInputComponent`)
    writes a hidden `<input name="code">`, and the backup-code
    fallback below renders an `<input name="backup_code">`. A prior
    iteration shared `name="code"` across both fields; that produced
    a regression where the empty backup-code input clobbered the
    filled segmented hidden field at submit time (Rack picks the LAST
    value for repeated names), silently sending `code=""` to the
    backend and failing every TOTP attempt. The backend tries TOTP on
    `params[:code]` and falls back to backup-code consumption on
    `params[:backup_code]` (with `params[:code]` as a wire-format
    compatibility shim for older JSON / spec callers that only carry
    `code`). %>
<div style="max-width: 420px; margin: 24px 0;">
  <h1>2FA</h1>
  <p class="text-muted" style="margin-top: 2px;">
    enter the 6-digit code from your authenticator app.
  </p>

  <%= form_with url: login_totp_path, method: :post, data: { turbo: false } do %>
    <div style="margin-bottom: 12px;">
      <%= render TotpCodeInputComponent.new(field: :code, autofocus: true) %>
    </div>

    <%# Backup-code fallback — distinct `backup_code` param so it
        does NOT collide with the segmented input's hidden `code`
        field. A shared `name="code"` would let the empty backup
        input override the filled segmented value at submit time
        (Rack picks the LAST repeated key), silently sending
        `code=""`. The bare input is the only path for an 8-char
        alphanumeric backup code; the 6-digit grid cannot accept it. %>
    <details style="margin-bottom: 12px;">
      <summary class="text-muted" style="cursor: pointer;">
        no access to the authenticator? use a backup code
      </summary>
      <div style="margin-top: 8px;">
        <%= label_tag :backup_code, "backup code" %><br>
        <%= text_field_tag :backup_code, nil,
                           autocomplete: "off",
                           inputmode: "text",
                           maxlength: 8 %>
      </div>
    </details>

    <div style="display: flex; gap: 6px; align-items: center;">
      <button type="submit" class="bracketed" style="cursor: pointer;">[<span class="bl">verify</span>]</button>
      <%= render BracketedMutedLinkComponent.new(label: "back", href: login_path) %>
    </div>
  <% end %>
</div>
