<%= helpers.turbo_frame_tag frame_id do %>
  <% if query.blank? %>
    <p class="text-muted"><%= t("games.omnisearch.placeholder_default") %></p>
  <% else %>
    <% if bundle_add? %>
      <%# :bundle_add — local games (existing-member exclusion handled
          server-side) + IGDB. No bundles section in this mode. %>
      <% if has_local_games? %>
        <%= render Search::OmnisearchSectionComponent.new(
              heading:    t("bundles.omnisearch.section_local"),
              empty_copy: t("games.omnisearch.no_results", query: query),
              empty:      false,
              first:      true
            ) do %>
          <% result.local_games.each do |game| %>
            <li class="omnisearch-row"><%= render Search::OmnisearchResultRowComponent.new(
                  kind: :local_game_add_to_bundle, record: game, bundle: bundle
                ) %></li>
          <% end %>
        <% end %>
      <% end %>

      <% if has_igdb? %>
        <% if igdb_error.present? %>
          <% unless has_local_games? %>
            <%# first section: no leading hairline %>
          <% else %>
            <hr class="hairline" style="margin: 12px 0;">
          <% end %>
          <section class="omnisearch-section">
            <h3 class="omnisearch-section-heading"><%= t("games.omnisearch.section_igdb") %></h3>
            <p class="text-danger"><%= t("games.omnisearch.igdb_error", msg: igdb_error[:message]) %></p>
          </section>
        <% else %>
          <%= render Search::OmnisearchSectionComponent.new(
                heading:    t("games.omnisearch.section_igdb"),
                empty_copy: t("games.omnisearch.no_igdb_results", query: query),
                empty:      false,
                first:      !has_local_games?
              ) do %>
            <% result.igdb.each do |row| %>
              <li class="omnisearch-row"><%= render Search::OmnisearchResultRowComponent.new(
                    kind: :igdb_add_to_bundle, igdb_row: row, bundle: bundle
                  ) %></li>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <% if result.local_games.empty? && result.igdb.empty? && igdb_error.blank? %>
        <p class="text-muted"><%= t("games.omnisearch.no_results", query: query) %></p>
      <% end %>

    <% elsif games_search? %>
      <%# :games_search — local games + local bundles + IGDB. %>
      <% if has_local_games? %>
        <%= render Search::OmnisearchSectionComponent.new(
              heading:    t("games.omnisearch.section_games"),
              empty_copy: t("games.omnisearch.no_results", query: query),
              empty:      false,
              first:      true
            ) do %>
          <% result.local_games.each do |game| %>
            <li class="omnisearch-row"><%= render Search::OmnisearchResultRowComponent.new(
                  kind: :local_game_link, record: game
                ) %></li>
          <% end %>
        <% end %>
      <% end %>

      <% if has_local_bundles? %>
        <%= render Search::OmnisearchSectionComponent.new(
              heading:    t("games.omnisearch.section_bundles"),
              empty_copy: t("games.omnisearch.no_results", query: query),
              empty:      false,
              first:      !has_local_games?
            ) do %>
          <% result.local_bundles.each do |b| %>
            <li class="omnisearch-row"><%= render Search::OmnisearchResultRowComponent.new(
                  kind: :local_bundle_link, record: b
                ) %></li>
          <% end %>
        <% end %>
      <% end %>

      <% if has_igdb? %>
        <% if igdb_error.present? %>
          <% if has_local_games? || has_local_bundles? %>
            <hr class="hairline" style="margin: 12px 0;">
          <% end %>
          <section class="omnisearch-section">
            <h3 class="omnisearch-section-heading"><%= t("games.omnisearch.section_igdb") %></h3>
            <p class="text-danger"><%= t("games.omnisearch.igdb_error", msg: igdb_error[:message]) %></p>
          </section>
        <% else %>
          <%= render Search::OmnisearchSectionComponent.new(
                heading:    t("games.omnisearch.section_igdb"),
                empty_copy: t("games.omnisearch.no_igdb_results", query: query),
                empty:      false,
                first:      !(has_local_games? || has_local_bundles?)
              ) do %>
            <% result.igdb.each do |row| %>
              <%# Dispatcher dedupes IGDB rows by local igdb_id, so every
                  row here is net-new. Always [add]. %>
              <li class="omnisearch-row"><%= render Search::OmnisearchResultRowComponent.new(
                    kind: :igdb_add,
                    igdb_row: row
                  ) %></li>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <% if truly_empty? %>
        <p class="text-muted"><%= t("games.omnisearch.no_results", query: query) %></p>
      <% end %>
    <% end %>
  <% end %>
<% end %>
