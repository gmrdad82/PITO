<% case kind %>
<% when :local_game_link %>
  <%= link_to game_path(record),
              data: { turbo_frame: "_top" },
              style: "flex: 1; text-decoration: none; color: inherit;" do %>
    <%= record.title %>
    <% if record.release_year %>
      <span class="text-muted">(<%= record.release_year %>)</span>
    <% end %>
  <% end %>
  <span class="text-muted" style="font-size: 11px;"><%= t("games.omnisearch.row_kind_game") %></span>

<% when :igdb_add %>
  <span style="flex: 1;">
    <%= igdb_row["name"] %>
    <% if igdb_release_year %>
      <span class="text-muted">(<%= igdb_release_year %>)</span>
    <% end %>
  </span>
  <%= button_to games_path,
                params: { game: { igdb_id: igdb_row["id"], title: igdb_row["name"] } },
                method: :post,
                class: "bracketed",
                form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl"><%= t("common.actions.add") %></span>]<% end %>
<% end %>
