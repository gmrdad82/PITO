<%#
  Tui::TstNoticeComponent — centered ephemeral notice for the TST.

  Root host is a <span> (inline, occupies the center flex slot in the
  parent TST). On SSR the slot is empty (the controller patches it
  on `tui:notice` events). The slot is set up with
  `data-tui-notice-target="slot"` so the controller knows where to
  write the message. `data-severity` on the root receives the current
  severity for CSS targeting (`.tui-tst-notice[data-severity="warn"]`
  etc.).
%>
<span class="tui-tst-notice"
      data-controller="tui-notice"
      data-tui-notice-duration-value="<%= duration_ms %>"
      data-severity="none">
  <span class="tui-tst-notice__slot" data-tui-notice-target="slot"></span>
</span>
