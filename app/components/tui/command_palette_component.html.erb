<%# FB-170 (2026-05-21) — V6 command palette template.
    FB-D4  (2026-05-22) — i18n + mode dispatch contract lock.

    Two stacked regions (suggestion list above, input bar below), both
    `position: fixed` at the viewport bottom. Hidden by default via
    the [hidden] attribute on the root; the Stimulus controller flips
    `hidden` off when `:` opens the palette.

    `data-tui-command-palette-commands-value` carries the JSON-encoded
    command catalog so the controller can filter / select / execute
    without a server round-trip per keystroke.

    `data-tui-command-palette-empty-value` carries the i18n "no matches"
    string so the JS controller emits it without a hardcoded literal. %>
<div class="tui-command-palette"
     hidden
     data-controller="tui-command-palette"
     data-tui-command-palette-commands-value="<%= commands_json %>"
     data-tui-command-palette-empty-value="<%= t("tui.command_palette.empty") %>">
  <div class="tui-command-palette__list" data-tui-command-palette-target="list">
    <%# Populated dynamically by the Stimulus controller after
        filtering. The empty state shows a single muted "no matches"
        row sourced from the i18n data attribute above. %>
  </div>
  <div class="tui-command-palette__foot">
    <span><%= t("tui.command_palette.footer.next") %></span>
    <span class="tui-command-palette__sep"><%= t("tui.command_palette.separator") %></span>
    <span><%= t("tui.command_palette.footer.cycle") %></span>
    <span class="tui-command-palette__sep"><%= t("tui.command_palette.separator") %></span>
    <span><%= t("tui.command_palette.footer.run") %></span>
    <span class="tui-command-palette__sep"><%= t("tui.command_palette.separator") %></span>
    <span><%= t("tui.command_palette.footer.close") %></span>
  </div>
  <div class="tui-command-palette__line">
    <span class="tui-command-palette__prompt">:</span>
    <input type="text"
           class="tui-command-palette__input"
           data-tui-command-palette-target="input"
           data-action="input->tui-command-palette#filter keydown->tui-command-palette#keydown"
           autocomplete="off"
           spellcheck="false"
           placeholder="<%= t("tui.command_palette.prompt_placeholder") %>">
  </div>
</div>
