<%#
  Beta 4 — Phase F1. Bottom status bar template. Composes the four
  sub-VCs: ModeLozengeComponent (left), ScreensListComponent (center),
  HelpHintComponent + CommandHintComponent (right). A separate dispatch
  wires the `tui-bottom-status-bar` Stimulus controller; the
  data-controller attribute is mounted here so the JS dispatch only needs
  to drop the controller file in.
%>
<footer class="bsb-bar" data-controller="tui-bottom-status-bar">
  <%= render Tui::ModeLozengeComponent.new(mode: mode) %>
  <span class="bsb-pipe"><%= pipe_label %></span>
  <%= render Tui::ScreensListComponent.new(current_section: current_section) %>
  <span class="bsb-pipe"><%= pipe_label %></span>
  <span class="bsb-hints">
    <%= render Tui::HelpHintComponent.new %>
    <span class="bsb-hint-spacer"></span>
    <%= render Tui::CommandHintComponent.new %>
  </span>
</footer>
