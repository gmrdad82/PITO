<%# D9 (2026-05-22) — body flows through Tui::DialogComponent. The chrome
    (title-in-border, [Esc] to close, backdrop guard) lives in the canonical
    wrapper; this template owns the keybinding tree. %>
<%= render Tui::DialogComponent.new(
      id: Tui::HelpDialogComponent::DIALOG_ID,
      title: t("tui.help.title"),
      extra_classes: "tui-help-dialog",
      extra_controllers: "tui-help-dialog"
    ) do %>
  <div class="tui-help-dialog__panel">
    <div class="tui-help-dialog__groups">
      <% GROUPS.each do |group| %>
        <section class="tui-help-dialog__group">
          <h3 class="tui-help-dialog__group-title"><%= t("help.overlay.groups.#{group[:group_key]}.title") %></h3>
          <dl class="tui-help-dialog__keys">
            <% group[:items].each do |item| %>
              <dt class="tui-help-dialog__key"><%= item[:key] %></dt>
              <dd class="tui-help-dialog__label"><%= t("help.overlay.groups.#{group[:group_key]}.items.#{item[:label_key]}") %></dd>
            <% end %>
          </dl>
        </section>
      <% end %>
    </div>
  </div>
<% end %>
