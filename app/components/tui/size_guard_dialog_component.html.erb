<%# Phase 1C (2026-05-22) — body flows through Tui::DialogComponent.
    The chrome (title-in-border, [Esc] to close, backdrop guard) lives
    in the canonical wrapper; this template only owns the message
    paragraph markup. Pattern parity with Tui::AlertDialogComponent. %>
<%= render Tui::DialogComponent.new(
      id: Tui::SizeGuardDialogComponent::DIALOG_ID,
      title: title,
      extra_classes: "tui-size-guard-dialog",
      extra_controllers: "tui-size-guard"
    ) do %>
  <p class="tui-size-guard-dialog__message"><%= message %></p>
<% end %>
