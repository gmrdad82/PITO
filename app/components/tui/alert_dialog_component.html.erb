<%# D9 (2026-05-22) — body now flows through Tui::DialogComponent. The
    chrome (title-in-border, [Esc] to close, backdrop guard) lives in the
    canonical wrapper; this template only owns the message-line markup. %>
<%= render Tui::DialogComponent.new(
      id: id,
      title: title,
      extra_classes: "tui-alert-dialog",
      extra_controllers: "tui-alert-dialog"
    ) do %>
  <% message_lines.each do |line| %>
    <p class="tui-alert-dialog__line"><%= line %></p>
  <% end %>
<% end %>
