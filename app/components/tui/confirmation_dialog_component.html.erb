<%# D9 (2026-05-22) — body now flows through Tui::DialogComponent. The
    chrome (title-in-border, [Esc] to cancel, backdrop guard) lives in the
    canonical wrapper; this template owns the message + action submit. %>
<%= render Tui::DialogComponent.new(
      id: id,
      title: title,
      esc_hint_key: "tui.dialog.esc_to_cancel",
      extra_classes: "tui-confirmation-dialog",
      extra_controllers: "tui-confirmation-dialog"
    ) do %>
  <p class="tui-confirmation-dialog__message"><%= message %></p>
  <%= form_with url: action_path, method: action_method, class: "tui-confirmation-dialog__form" do %>
    <span data-tui-focusable="confirm" data-tui-focusable-style="action">
      <%= render BracketedLinkComponent.new(label: action_label, as: :submit, destructive: destructive?) %>
    </span>
  <% end %>
<% end %>
