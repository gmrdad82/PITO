<%# D9 (2026-05-22) — body flows through Tui::DialogComponent. The chrome
    (title-in-border, [Esc] to close, backdrop guard) lives in the canonical
    wrapper; this template owns the identity card (name + KV grid +
    copyright). %>
<%= render Tui::DialogComponent.new(
      id: Tui::AboutDialogComponent::DIALOG_ID,
      title: t("tui.about.title"),
      extra_classes: "tui-about-dialog"
    ) do %>
  <div class="tui-about-dialog__inner">
    <%# Logo above the project name. 64px display size sourced from
        `/favicon-128x128.png` for ~2x retina density. %>
    <img src="/favicon-128x128.png?v=2" alt="<%= t("tui.about.app_name") %>"
         class="tui-about-dialog__logo">

    <%# Project identity block — name + muted subtitle. %>
    <div class="tui-about-dialog__identity">
      <div><%= t("tui.about.app_name") %></div>
      <div class="text-muted"><%= t("tui.about.subtitle") %></div>
    </div>

    <%# KV grid — version / license / source / commit / contact / env.
        Two-column grid centered in the dialog; labels right-aligned,
        values left-aligned. The visual gap at the middle aligns with
        the centered "pito" word above. No colons — the grid itself
        communicates K-V. %>
    <dl class="tui-about-dialog__kv">
      <dt class="text-muted"><%= t("tui.about.version_label") %></dt>
      <dd>
        <%= render BracketedLinkComponent.new(label: version_string, href: version_url) %>
      </dd>

      <dt class="text-muted"><%= t("tui.about.license_label") %></dt>
      <dd>
        <%= render BracketedLinkComponent.new(label: t("tui.about.license_value"), href: license_url) %>
      </dd>

      <dt class="text-muted"><%= t("tui.about.source_label") %></dt>
      <dd>
        <%= render BracketedLinkComponent.new(label: t("tui.about.source_value"), href: source_url) %>
      </dd>

      <% if commit_short_sha %>
        <dt class="text-muted"><%= t("tui.about.commit_label") %></dt>
        <dd>
          <% if commit_url %>
            <%= render BracketedLinkComponent.new(label: commit_short_sha, href: commit_url) %>
          <% else %>
            <%= commit_short_sha %>
          <% end %>
        </dd>
      <% end %>

      <dt class="text-muted"><%= t("tui.about.contact_label") %></dt>
      <dd><%= t("tui.about.contact_value") %></dd>

      <dt class="text-muted"><%= t("tui.about.env_label") %></dt>
      <dd><%= env %></dd>
    </dl>

    <%# Copyright line — mirrors the footer string. %>
    <div class="text-muted tui-about-dialog__copyright">
      <%= copyright_text %>
    </div>
  </div>
<% end %>
