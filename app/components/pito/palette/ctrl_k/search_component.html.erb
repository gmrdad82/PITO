<%# Title row %>
<div class="flex justify-between items-center px-1.5">
  <span class="font-bold text-fg"><%= t("pito.palette.ctrl_k.title") %></span>
  <%= render(Pito::Keybinding::ShortcutComponent.new(keys: t("pito.palette.ctrl_k.esc_hint"))) %>
</div>

<div class="h-3"></div>

<div class="flex items-center pb-1 border-b border-line-default mx-1.5">
  <%# Wrapped so the terminal block caret + trail ride along (input mode).
      Already font-mono; .pito-caret-input adds caret-color:transparent. %>
  <div class="relative w-full" data-controller="pito--terminal-caret pito--cursor-trail">
    <input type="text"
           data-pito--command-palette-target="search"
           data-pito--terminal-caret-target="field"
           data-action="input->pito--command-palette#filter"
           placeholder="<%= t('pito.palette.ctrl_k.search_placeholder') %>"
           autocomplete="off"
           class="bg-transparent text-fg outline-none w-full placeholder:text-fg-dim font-mono text-base pito-caret-input">
    <span class="terminal-caret" data-pito--terminal-caret-target="block" aria-hidden="true"></span>
  </div>
</div>
