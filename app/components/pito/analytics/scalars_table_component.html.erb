<div class="pito-analytics-scalars grid grid-cols-6 gap-x-6 gap-y-1">
  <%# Row 1: Views | Watch hours (col-span-3 each) %>
  <% row1_cells.each do |cell| %>
    <div class="col-span-3 flex items-baseline justify-between gap-x-3">
      <span class="text-fg-dim whitespace-nowrap"><%= cell[:label] %></span>
      <span class="tabular-nums text-right"><%= render(cell[:trend]) %></span>
    </div>
  <% end %>

  <%# Row 2: Avg view duration | Avg viewed % (col-span-3 each) %>
  <% row2_cells.each do |cell| %>
    <div class="col-span-3 flex items-baseline justify-between gap-x-3">
      <span class="text-fg-dim whitespace-nowrap"><%= cell[:label] %></span>
      <span class="tabular-nums text-right"><%= render(cell[:trend]) %></span>
    </div>
  <% end %>

  <%# Row 3: Subs net — left half only (col-span-3) so its value lines up in the
      same column as Views above, not stretched across the full width. %>
  <% subs = row3_subs_net %>
  <div class="col-span-3 flex items-baseline justify-between gap-x-3">
    <span class="text-fg-dim whitespace-nowrap"><%= subs[:label] %></span>
    <span class="tabular-nums text-right"><%= render(subs[:trend]) %></span>
  </div>

  <%# Row 4: Likes | Dislikes | Comms (col-span-2 each) %>
  <% row4_cells.each do |cell| %>
    <div class="col-span-2 flex items-baseline justify-between gap-x-3">
      <span class="text-fg-dim whitespace-nowrap"><%= cell[:label] %></span>
      <span class="tabular-nums text-right"><%= render(cell[:trend]) %></span>
    </div>
  <% end %>
</div>
