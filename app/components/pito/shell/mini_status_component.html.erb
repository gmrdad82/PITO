<% if @mode == :start %>
  <span class="text-red"><%= t("pito.shell.mini_status.not_authenticated") %></span>
<% else %>
  <span class="<%= connection_class %>"><%= connection_label %></span>
<% end %>
<% if @show_notifications && @notifications > 0 %>
  <span class="text-fg-faded mx-2">·</span>
  <span class="text-cyan"><%= t("pito.shell.mini_status.notifications_count", count: @notifications) %></span>
<% end %>
<span class="text-fg-faded mx-2">·</span>
<span class="font-bold text-yellow"><%= t("pito.shell.mini_status.commands_hint") %></span>
<span class="text-fg-dim ml-1"><%= t("pito.shell.mini_status.commands_label") %></span>
