<%# U7 — Start screen. Full-viewport centered layout, no auth required. %>
<%# ASCII logo per ui-p2.md, chatbox at 50vh, tip line + bottom corners below. %>

<div class="flex flex-col min-h-screen">
  <%# Top spacer — pushes centered group toward 50vh %>
  <div class="flex-1"></div>

  <%# Centered group %>
  <div class="flex flex-col items-center">
    <%# ASCII logo — 6 rows, brand-pito blocks + fg-dim shadow chars, 18px %>
    <pre class="pito-start-screen__logo">
<span class="text-pito">██████</span><span class="text-fg-dim">╗ </span><span class="text-pito">██</span><span class="text-fg-dim">╗</span><span class="text-pito">████████</span><span class="text-fg-dim">╗ </span><span class="text-pito">██████</span><span class="text-fg-dim">╗ </span>
<span class="text-pito">██</span><span class="text-fg-dim">╔══</span><span class="text-pito">██</span><span class="text-fg-dim">╗</span><span class="text-pito">██</span><span class="text-fg-dim">║╚══</span><span class="text-pito">██</span><span class="text-fg-dim">╔══╝</span><span class="text-pito">██</span><span class="text-fg-dim">╔═══</span><span class="text-pito">██</span><span class="text-fg-dim">╗</span>
<span class="text-pito">██████</span><span class="text-fg-dim">╔╝</span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║</span>
<span class="text-pito">██</span><span class="text-fg-dim">╔═══╝ </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║</span>
<span class="text-pito">██</span><span class="text-fg-dim">║     </span><span class="text-pito">██</span><span class="text-fg-dim">║   </span><span class="text-pito">██</span><span class="text-fg-dim">║   ╚</span><span class="text-pito">██████</span><span class="text-fg-dim">╔╝</span>
<span class="text-fg-dim">╚═╝     ╚═╝   ╚═╝    ╚═════╝ </span>
</pre>

    <%# 32px gap %>
    <div class="h-8"></div>

    <%# Chatbox form — posts to POST /chat (no uuid = new conversation) %>
    <div class="w-full max-w-[600px] px-4">
      <%= form_with url: chat_path, method: :post,
                    data: { controller: "pito--chat-form", turbo: true },
                    class: "chatbox-form" do |form| %>
        <%= form.hidden_field :input, data: { pito__chat_form_target: "hiddenInput" } %>

        <%= render(Pito::Shell::ChatboxComponent.new(
              state: :start,
              input_data: { pito__chat_form_target: "inputField" }
            )) %>
      <% end %>
    </div>

    <%# Mini-status row — right-aligned to chatbox right edge %>
    <div class="mt-2 w-full max-w-[600px] px-4">
      <div class="flex justify-end">
        <%= render(Pito::Shell::MiniStatusComponent.new(mode: :start)) %>
      </div>
    </div>
  </div>

  <%# Spacer between centered group and bottom area — tip lives inside this %>
  <div class="flex-1 flex flex-col justify-center items-center p-4">
    <%# Tip line — orange bullet + prefix in yellow + dim placeholder text %>
    <span class="text-fg-faded">
      <span class="text-orange">●</span>
      <span class="font-bold text-yellow"><%= t("pito.start_screen.tip_prefix") %></span>
      <span> — </span>
      <span><%= t("pito.start_screen.tip_placeholder") %></span>
    </span>
  </div>

  <%# Bottom corners %>
  <div class="flex justify-between px-[50px] pb-8">
    <% if @marketing_url.present? %>
      <a href="<%= @marketing_url %>" class="text-fg-dim hover:underline" target="_blank"><%= URI.parse(@marketing_url).host || @marketing_url %></a>
    <% else %>
      <span></span>
    <% end %>
    <span class="text-fg-dim">v<%= @version %></span>
  </div>
</div>
