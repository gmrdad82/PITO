<%# Pito::ScoreBarComponent — continuous-gradient text bar + absolute tick overlay
    + absolute score bubble. The `=` run between the brackets is ONE
    span (no mid-string tick). The `|` tick and the numeric score
    bubble float on top at `left: <score>%`. When the score is nil or
    the game is resyncing the bar renders muted with no overlay.
    CSS hooks: .rating-heat-bar (legacy) and .pito-score-bar (canonical).
    The legacy hook is kept until Game::RatingHeatBarComponent alias is dropped. %>
<% s = score %>
<% if s.nil? && !resyncing? %>
  <span class="rating-heat-bar pito-score-bar rating-heat-bar--muted pito-score-bar--muted"
        data-tier="missing">
    <span class="rating-heat-bar__track pito-score-bar__track"><span class="rating-heat-bar__bracket pito-score-bar__bracket">[</span><span class="rating-heat-bar__fill pito-score-bar__fill"><%= fill_text %></span><span class="rating-heat-bar__bracket pito-score-bar__bracket">]</span></span>
  </span>
<% else %>
  <span class="rating-heat-bar pito-score-bar"
        data-score="<%= s %>"
        data-tier="<%= tier %>"
        data-resyncing="<%= resyncing? ? "yes" : "no" %>">
    <span class="rating-heat-bar__track pito-score-bar__track"><span class="rating-heat-bar__bracket pito-score-bar__bracket">[</span><span class="rating-heat-bar__fill pito-score-bar__fill"><%= fill_text %></span><span class="rating-heat-bar__bracket pito-score-bar__bracket">]</span></span>
    <% if overlay? %>
      <% pct = overlay_left_percent %>
      <span class="rating-heat-bar__bubble pito-score-bar__bubble" style="left: <%= pct %>%;"><span class="rating-heat-bar__bubble-num pito-score-bar__bubble-num"><%= s %></span><span class="rating-heat-bar__bubble-arrow pito-score-bar__bubble-arrow">&#9660;</span></span>
      <span class="rating-heat-bar__tick pito-score-bar__tick" style="left: <%= pct %>%;">|</span>
    <% end %>
  </span>
<% end %>
