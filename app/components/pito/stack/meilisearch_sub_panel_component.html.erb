<%# Pito::Stack::MeilisearchSubPanelComponent — Meilisearch sub-panel
    inside the stack panel on Home.

    FB-126 (2026-05-21) — `[reindex]` opens a confirmation dialog
    mounted by the parent `Pito::StackPanelComponent` (id
    `reindex_meilisearch_confirmation`). The `reindex-action` Stimulus
    controller swaps idle ↔ running slots on the cable
    `reindex_started` event + the `ensure`-block re-broadcast.

    FB-165 — idle slot's button is the j/k focusable for this
    sub-panel. The running slot drops out of the focus list
    automatically via `offsetParent === null` once `hidden` flips on.

    FB-166 — focusable style declared in Ruby
    (`SettingsHelper#stack_reindex_focusables`). The running state
    emits an empty focusables list, so the cursor list skips this
    slot during a reindex. %>
<%= render Tui::SubPanelComponent.new(title: t("settings.stack.meilisearch")) do |c| %>
  <% c.with_actions do %>
    <%= render Tui::ChipComponent.new(label: chip[:chip_label], variant: chip[:chip_variant]) %>
    <span data-controller="reindex-action"
          data-reindex-action-brand-value="meilisearch">
      <% _meili_f = focusables.first %>
      <span data-reindex-action-target="idle" <%= "hidden" if reindex_running? %>>
        <%# FB-178 (2026-05-21) — `data-reindex-brand="meilisearch"`
            is the canonical hook the `:command` palette uses to
            programmatically click this button. ADR 0018 —
            `data-action-name` routes the click through
            `window.Pito.dispatchAction(:reindex_meilisearch)`. %>
        <%= render Tui::ActionButtonComponent.new(
          action_name: :reindex_meilisearch,
          label: t("settings.stack.meilisearch_reindex_label"),
          focusable: _meili_f,
          data: { reindex_brand: "meilisearch" },
        ) %>
      </span>
      <span data-reindex-action-target="running" <%= "hidden" unless reindex_running? %>>
        <%= render Tui::ReindexProgressComponent.new(brand: "meilisearch") %>
      </span>
    </span>
  <% end %>

  <% if per_index_stats.any? %>
    <div data-controller="sortable-table" data-sortable-table-id-value="stack-meilisearch">
      <table class="tui-table tui-table--stack" data-sortable-table-target="table">
        <thead>
          <tr>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_index"), sort_type: "string")) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_docs"), sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_size"), sort_type: "number", numeric: true)) %>
          </tr>
        </thead>
        <tbody>
          <%# The unified `games_<env>` Meilisearch index is split
              into two rows by `kind` (`game` / `bundle`). Size is
              reported by Meilisearch at the INDEX level only;
              `omit_size` rows render a plain dash in the size
              column (the size is already attributed to the
              `games` row, so duplicating it on `bundles` would
              mislead the operator). %>
          <% per_index_stats.each do |row| %>
            <% key = row[:label].to_s.camelize %>
            <tr class="tui-table__row">
              <td class="tui-table__td"><%= row[:label] %></td>
              <% if row[:missing] %>
                <td class="tui-table__td tui-table__td--right num text-muted" colspan="2">
                  <span data-sort-value="-1"><%= t("settings.stack.not_yet_indexed") %></span>
                </td>
              <% else %>
                <td class="tui-table__td tui-table__td--right num">
                  <span data-sort-value="<%= row[:documents].to_i %>"
                        data-stack-stats-live-target="meilisearch<%= key %>Docs">
                    <%= number_with_delimiter(row[:documents].to_i) %>
                  </span>
                </td>
                <% if row[:omit_size] %>
                  <td class="tui-table__td tui-table__td--right num text-muted">
                    <span data-sort-value="-1">—</span>
                  </td>
                <% else %>
                  <td class="tui-table__td tui-table__td--right num">
                    <span data-sort-value="<%= row[:size_bytes] || -1 %>"
                          data-stack-stats-live-target="meilisearch<%= key %>Size">
                      <%= helpers.human_filesize_int(row[:size_bytes]) %>
                    </span>
                  </td>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
