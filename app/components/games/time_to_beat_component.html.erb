<%# Single canonical visualization — the fuel gauge. The bar spans the
    full pane width and represents hours (not percentages) along its
    x-axis. See `time_to_beat_component.rb` for the layout sketch and
    the 4-zone color rationale. %>
<%
  h_main          = hours[:main].to_i
  h_extras        = hours[:extras].to_i
  h_completionist = hours[:completionist].to_i
  footage         = footage_hours

  main_pos        = position(h_main)
  extras_pos      = position(h_extras)
  compl_pos       = position(h_completionist)
  footage_pos     = position(footage)

  # Zone boundary positions (in % of max_x). Each band spans from the
  # previous boundary (or 0) to its own position; the open-ended top
  # band runs from the last boundary to 100%.
  z_10   = position(10)
  z_40   = position(40)
  z_100  = position(100)
%>

<div class="ttb-fuel-gauge" data-component="time-to-beat" data-variant="fuel_gauge">
  <%# Footage label row — single line above the gauge, only when we
      have a footage value to communicate. Uses --color-text for
      contrast so the "recorded Nh" tag reads as the focal text. %>
  <% if render_footage_tick? %>
    <div class="ttb-fuel-gauge__footage-row">
      <span class="ttb-fuel-gauge__footage-label"
            style="left: <%= footage_pos %>%;">
        <%= footage_label %>
      </span>
    </div>
  <% end %>

  <%# Pillar VALUE labels row (hours above each tick). %>
  <div class="ttb-fuel-gauge__values">
    <span class="ttb-fuel-gauge__value" style="left: <%= main_pos %>%;">
      <%= label_for(:main) %>
    </span>
    <span class="ttb-fuel-gauge__value" style="left: <%= extras_pos %>%;">
      <%= label_for(:extras) %>
    </span>
    <span class="ttb-fuel-gauge__value" style="left: <%= compl_pos %>%;">
      <%= label_for(:completionist) %>
    </span>
  </div>

  <%# The bar itself. The 4 zone backgrounds are layered as absolutely-
      positioned divs so each band gets its own literal hex (no
      gradient — the user wanted clear "this is low / some / commitment
      / insanity" zones, not a smooth ramp). %>
  <div class="ttb-fuel-gauge__bar">
    <%# Zone 1 — 0-10h "low effort" — muted dark grey #4a4d5c %>
    <div class="ttb-fuel-gauge__zone ttb-fuel-gauge__zone--low"
         style="left: 0; width: <%= z_10 %>%;"></div>
    <%# Zone 2 — 10-40h "some effort" — muted slate #5a6a7a %>
    <div class="ttb-fuel-gauge__zone ttb-fuel-gauge__zone--some"
         style="left: <%= z_10 %>%; width: <%= [z_40 - z_10, 0].max %>%;"></div>
    <%# Zone 3 — 40-100h "commitment" — steel blue #5a7a9a %>
    <div class="ttb-fuel-gauge__zone ttb-fuel-gauge__zone--commitment"
         style="left: <%= z_40 %>%; width: <%= [z_100 - z_40, 0].max %>%;"></div>
    <%# Zone 4 — 100h+ "insanity" — muted plum #7a5a9a %>
    <div class="ttb-fuel-gauge__zone ttb-fuel-gauge__zone--insanity"
         style="left: <%= z_100 %>%; width: <%= [100 - z_100, 0].max %>%;"></div>

    <%# Pillar ticks — thin (2px), no border, just a clean
        text-colored vertical line. Overshoots the bar by 3px top
        and bottom so the tick reads as a marker, not a fill stripe. %>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar"
         style="left: <%= main_pos %>%;"
         data-pillar="main"></div>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar"
         style="left: <%= extras_pos %>%;"
         data-pillar="extras"></div>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar"
         style="left: <%= compl_pos %>%;"
         data-pillar="completionist"></div>

    <%# Footage tick — bigger (4px), with theme-aware border so it
        reads as the bordered "you are here" notch (mirrors the
        rating heat-bar's `.rating-heat-bar-indicator` style — page-bg
        fill + text-color border). Always overlaid on top of the
        pillar ticks via stacking order. %>
    <% if render_footage_tick? %>
      <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--footage"
           style="left: <%= footage_pos %>%;"
           data-footage-hours="<%= footage %>"></div>
    <% end %>
  </div>

  <%# Pillar NAME labels row (below the bar). %>
  <div class="ttb-fuel-gauge__names">
    <span class="ttb-fuel-gauge__name" style="left: <%= main_pos %>%;">
      <%= PILLAR_LABEL[:main] %>
    </span>
    <span class="ttb-fuel-gauge__name" style="left: <%= extras_pos %>%;">
      <%= PILLAR_LABEL[:extras] %>
    </span>
    <span class="ttb-fuel-gauge__name" style="left: <%= compl_pos %>%;">
      <%= PILLAR_LABEL[:completionist] %>
    </span>
  </div>
</div>
