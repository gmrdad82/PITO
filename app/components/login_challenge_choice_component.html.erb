<div class="dot-list" style="margin-top: 12px;">
  <%= form_with url: login_challenge_path, method: :post, scope: nil, data: { turbo: false }, html: { style: "display: inline;" } do %>
    <input type="hidden" name="challenge_path" value="<%= LoginChallengeChoiceComponent::TOTP_PATH %>">
    <button type="submit" class="bracketed" style="cursor: pointer;">[<%= LoginChallengeChoiceComponent::TOTP_LABEL %>]</button>
  <% end %>

  <%= form_with url: login_challenge_path, method: :post, scope: nil, data: { turbo: false }, html: { style: "display: inline;" } do %>
    <input type="hidden" name="challenge_path" value="<%= LoginChallengeChoiceComponent::APPROVAL_PATH %>">
    <button type="submit" class="bracketed" style="cursor: pointer;">[<%= LoginChallengeChoiceComponent::APPROVAL_LABEL %>]</button>
  <% end %>
</div>
