<% case field_kind
   when :short_text %><%
     if empty? %><span class="text-muted">(empty)</span><%
     else %><span><%= value.to_s %></span><%
     end %><%
   when :long_text %><%
     if empty? %><span class="text-muted">(empty)</span><%
     else
       display, full = truncated_long_text %><%
       if full %><span title="<%= full %>"><%= display %></span><%
       else %><span><%= display %></span><%
       end %><%
     end %><%
   when :tags %><%
     if tags_empty? %><span class="text-muted">(empty)</span><%
     else %><%= safe_join(tag_list.map { |t| content_tag(:span, t, class: "diff-tag") }, " ") %><%
     end %><%
   when :boolean %><%
     if value.nil? %><span class="text-muted">(empty)</span><%
     else
       b = boolean_value %><%
       if b == true %><span>yes</span><%
       elsif b == false %><span>no</span><%
       else %><span><%= value.to_s %></span><%
       end %><%
     end %><%
   when :integer %><%
     if empty? %><span class="text-muted">(empty)</span><%
     else
       n = integer_display %><%
       if n %><span><%= number_with_delimiter(n) %></span><%
       else %><span><%= value.to_s %></span><%
       end %><%
     end %><%
   when :time %><%
     if empty? %><span class="text-muted">(empty)</span><%
     else
       t = time_value %><%
       if t %><span><%= t.utc.iso8601 %></span><%
       else %><span><%= value.to_s %></span><%
       end %><%
     end %><%
   when :url %><%
     if empty? %><span class="text-muted">(empty)</span><%
     else %><span style="word-break: break-all;"><%= value.to_s %></span><%
     end %><%
   end %>
