#!/usr/bin/env bash
# bin/test
#
# Convenience wrapper for the parallel test suite. Caps workers at 8 to
# match CI and bin/parallel_setup. Usage:
#
#     bin/test                  # full suite
#     bin/test spec/models      # subset
#     bin/test spec/foo_spec.rb # single file
#
# Equivalent to `PARALLEL_TEST_PROCESSORS=8 bundle exec parallel_rspec "$@"`.

set -euo pipefail
cd "$(dirname "$0")/.."
export PARALLEL_TEST_PROCESSORS=8
exec bundle exec parallel_rspec "$@"
