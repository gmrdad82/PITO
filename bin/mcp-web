#!/usr/bin/env bash
# Starts the MCP HTTP server on a dedicated Puma process (port 3028).
# This is separate from the web app Puma (port 3027).
#
# Usage:
#   bin/mcp-web                    # Starts on port 3028
#   MCP_PORT=3029 bin/mcp-web      # Custom port
#
# The MCP endpoint is at POST /mcp and requires a bearer token.
# Generate tokens with: bin/rails mcp:generate_token

set -euo pipefail

export PORT="${MCP_PORT:-3028}"

exec bundle exec puma -C config/puma_mcp.rb
