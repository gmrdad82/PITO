#!/usr/bin/env bash
# bin/test-full — full local suite WITH system specs, serial, live progress.

set -euo pipefail

cd "$(dirname "$0")/.."

bin/test-prepare

if [[ $# -gt 0 ]]; then
  exec bundle exec rspec --format progress --color --options /dev/null --require spec_helper "$@"
else
  exec bundle exec rspec --format progress --color --options /dev/null --require spec_helper spec
fi
