#!/usr/bin/env bash
# bin/test-prepare
#
# Conditional `db:test:prepare` shim. Skips the rake task when `db/schema.rb`
# has not changed since the last successful prepare, saving ~10-15s per local
# spec run.
#
# State file: `tmp/.test_db_prepared_at`. We compare its mtime to `db/schema.rb`
# and re-prepare only when the schema is newer (or the marker is missing).
#
# Used by `bin/test` before invoking the parallel runner. CI does NOT call this
# shim — CI runs `bin/rails db:create db:migrate db:seed` + `rake parallel:*`
# explicitly (see `.github/workflows/ci.yml`).
#
# Force a re-prepare:
#     rm tmp/.test_db_prepared_at && bin/test-prepare

set -euo pipefail

cd "$(dirname "$0")/.."

SCHEMA="db/schema.rb"
MARKER="tmp/.test_db_prepared_at"

if [[ ! -f "$SCHEMA" ]]; then
  echo "bin/test-prepare: $SCHEMA not found; skipping prepare." >&2
  exit 0
fi

mkdir -p tmp

if [[ -f "$MARKER" && "$MARKER" -nt "$SCHEMA" ]]; then
  # Marker is newer than the schema — DB is up to date with schema.rb.
  exit 0
fi

echo "bin/test-prepare: schema changed (or no marker); running db:test:prepare..." >&2
bin/rails db:test:prepare
touch "$MARKER"
