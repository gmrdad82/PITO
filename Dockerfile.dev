# syntax=docker/dockerfile:1
# Development image — source code is bind-mounted at runtime, not baked in.
# Installs all gems (including dev/test groups) and system tools for live reload.
#
# Usage (via docker-compose.dev.yml or bin/boot --dev):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build

ARG RUBY_VERSION=3.4.9
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# System deps: same as production base + build tools (needed for native gems)
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential curl git libpq-dev libpq5 libvips libyaml-dev \
      pkg-config postgresql-client ffmpeg imagemagick && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT=""

# Pre-install gems from Gemfile/Gemfile.lock so the layer is cached.
# The app code itself is mounted at runtime, so only gem files are copied here.
COPY Gemfile Gemfile.lock ./
COPY vendor/ ./vendor/
RUN bundle install

EXPOSE 3027

CMD ["./bin/dev"]
